---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { url } from '../lib/links.js';

const lib = [
  { id: 'B0mQ_NKd-rw', tag: 'OVERVIEW · ONE CALL DOES IT ALL', title: 'One Call Does It All', desc: 'Engineering, ranging, intercept, kill and cement — delivered end-to-end by one accountable team. Why Gunnar\'s integrated model eliminates multi-vendor handoffs on the wells that can\'t afford gaps.' },
  { id: 'c9gOxwwKouo', tag: 'OVERVIEW · WHAT WE DO', title: 'What Does Gunnar Do?', desc: 'A concise introduction to Gunnar Energy Services — the independent specialist that brings proprietary magnetic ranging technology and full-scope well-control capability to the industry\'s most complex wells.' },
  { id: 'iLe8lQrgoWg', tag: 'CASE STUDY · DIRECTIONAL DRILLING', title: 'A Breakthrough in Directional Drilling & Magnetic Ranging', desc: 'Inside a landmark intercept project — how Gunnar combined precision directional drilling with active magnetic ranging to hit a target other methods couldn\'t reach.' },
  { id: 'maealxT53lc', tag: 'MILESTONE · WORLD RECORD', title: 'World Record Intersect', desc: 'Gunnar executes the deepest wellbore intercept ever performed in the world — a landmark achievement that demonstrates the precision and range of active magnetic ranging at depths no one had reached before.' },
  { id: 'IHO-1q9tRcw', tag: 'EXPLAINER · WELL CONTROL', title: 'Well Control', desc: 'An overview of Gunnar\'s well-control capability — from blowout response to relief well planning, covering how our team mobilises fast and how active ranging keeps a kill operation on target.' },
  { id: 'u0VyeG-lT9c', tag: 'EXPLAINER · PULLING BACK THE CURTAIN', title: 'Passive Magnetic Ranging, Explained', desc: 'Founder Clinton Moss breaks down how passive magnetic ranging (EverReady™) locates a target wellbore using its existing magnetism — no extra rig time, no new tools downhole.' },
  { id: 'pznvpHUhyX8', tag: 'CONVERSATION · OIL & GAS STARTUPS', title: 'Gunnar on the Oil & Gas Startups Podcast', desc: 'The origin story of Gunnar Energy Services and why an independent specialist built its entire company around wellbore positioning and intercept.' },
];

const topics = [
  { t: 'Field Footage', b: 'Real intercept, kill and P&A operations from active projects.' },
  { t: 'Tech Explainers', b: 'Active vs. passive ranging, DeadAhead™, CTRWD™ and more — in plain language.' },
  { t: 'Engineer Talks', b: 'The people who pioneered the discipline on how and why it works.' },
  { t: 'Industry Topics', b: 'Relief wells, CCUS, geothermal and the future of wellbore placement.' },
];

const thumb = (id) => `https://i.ytimg.com/vi/${id}/hqdefault.jpg`;
const active = lib[0];
---
<Layout title="Video Library — Pulling Back the Curtain | Gunnar Energy Services" description="Field footage, magnetic ranging explainers and engineer conversations from the Gunnar Energy Services YouTube channel — playing right on the site.">
  <SiteHeader />

  <!-- HERO -->
  <section style="background:#0f2240;color:#eef1f6;position:relative;overflow:hidden;padding:60px 32px 64px;">
    <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(255,255,255,0.045) 1px,transparent 1px);background-size:28px 28px;opacity:0.6;"></div>
    <div style="position:absolute;top:-180px;right:-140px;width:520px;height:520px;border-radius:50%;border:1px solid rgba(254,238,0,0.14);"></div>
    <div style="max-width:1240px;margin:0 auto;position:relative;">
      <div style="font-family:'IBM Plex Mono',monospace;font-size:11.5px;letter-spacing:0.08em;color:#8493ac;margin-bottom:22px;"><a href={url('/')} style="color:#8493ac;">Home</a> &nbsp;/&nbsp; <span style="color:#feee00;">Videos</span></div>
      <div style="font-family:'IBM Plex Mono',monospace;font-size:12.5px;letter-spacing:0.18em;color:#feee00;margin-bottom:16px;">VIDEO LIBRARY · PULLING BACK THE CURTAIN</div>
      <h1 style="font-family:'Archivo',sans-serif;font-weight:900;font-size:50px;line-height:1.02;letter-spacing:-0.025em;margin:0 0 18px;max-width:20ch;">See the technology that hits the target.</h1>
      <p style="font-size:18px;line-height:1.55;color:#c3cee0;max-width:62ch;margin:0;">Field footage, plain-language explainers and conversations with the engineers who pioneered magnetic ranging — straight from our channel, playing right here.</p>
    </div>
  </section>

  <!-- FEATURED PLAYER -->
  <section style="padding:56px 32px 24px;background:#eef1f6;">
    <div style="max-width:1240px;margin:0 auto;">
      <div style="display:grid;grid-template-columns:1.55fr 1fr;gap:32px;align-items:start;">
        <div>
          <div id="vid-frame" data-video-frame style="position:relative;width:100%;aspect-ratio:16/9;background:#0a1626;overflow:hidden;border:1px solid #d9dfe9;">
            <div id="vid-facade" data-video-facade data-embed={`https://www.youtube-nocookie.com/embed/${active.id}?autoplay=1&rel=0&modestbranding=1`} data-title={active.title} style={`position:absolute;inset:0;cursor:pointer;background-image:url('${thumb(active.id)}');background-size:cover;background-position:center;`}>
              <div style="position:absolute;inset:0;background:linear-gradient(180deg,rgba(10,22,38,0.1),rgba(10,22,38,0.65));"></div>
              <div style="position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);width:84px;height:84px;border-radius:50%;background:#feee00;display:flex;align-items:center;justify-content:center;box-shadow:0 8px 30px rgba(0,0,0,0.35);">
                <div style="width:0;height:0;border-left:26px solid #0a1626;border-top:16px solid transparent;border-bottom:16px solid transparent;margin-left:6px;"></div>
              </div>
            </div>
          </div>
          <div style="margin-top:18px;">
            <div id="vid-tag" style="font-family:'IBM Plex Mono',monospace;font-size:10.5px;letter-spacing:0.12em;color:#1b355e;margin-bottom:8px;">{active.tag}</div>
            <h2 id="vid-title" style="font-family:'Archivo',sans-serif;font-weight:800;font-size:25px;letter-spacing:-0.01em;margin:0 0 8px;color:#0f2240;">{active.title}</h2>
            <p id="vid-desc" style="font-size:14.5px;line-height:1.6;color:#5f676e;margin:0;max-width:62ch;">{active.desc}</p>
          </div>
        </div>
        <div style="display:flex;flex-direction:column;">
          <div style="font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:0.14em;color:#1b355e;margin-bottom:14px;">UP NEXT</div>
          <div style="display:flex;flex-direction:column;gap:10px;max-height:460px;overflow-y:auto;padding-right:4px;">
            {lib.map((v, i) => (
              <div class="vid-row" data-idx={i} style={`display:grid;grid-template-columns:128px 1fr;gap:14px;cursor:pointer;background:${i === 0 ? 'var(--surface)' : 'transparent'};border:1px solid ${i === 0 ? 'var(--accent)' : 'var(--line)'};padding:10px;flex-shrink:0;`}>
                <div style={`position:relative;aspect-ratio:16/9;background-image:url('${thumb(v.id)}');background-size:cover;background-position:center;`}>
                  <div style="position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);width:30px;height:30px;border-radius:50%;background:rgba(254,238,0,0.95);display:flex;align-items:center;justify-content:center;">
                    <div style="width:0;height:0;border-left:10px solid #0a1626;border-top:6px solid transparent;border-bottom:6px solid transparent;margin-left:2px;"></div>
                  </div>
                </div>
                <div style="display:flex;flex-direction:column;justify-content:center;">
                  <div style="font-family:'IBM Plex Mono',monospace;font-size:9px;letter-spacing:0.1em;color:#1b355e;margin-bottom:5px;">{v.tag}</div>
                  <div style="font-size:13px;font-weight:600;color:#0f2240;line-height:1.25;">{v.title}</div>
                </div>
              </div>
            ))}
          </div>
          <a href="https://www.youtube.com/@GunnarEnergyServices" target="_blank" rel="noopener" style="margin-top:16px;border:1px solid var(--line-strong);color:var(--accent);font-family:var(--mono);font-size:12px;letter-spacing:0.1em;text-transform:uppercase;padding:13px 16px;text-align:center;flex-shrink:0;">Watch the full series on YouTube →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- FULL VIDEO GRID -->
  <section style="padding:48px 32px 16px;background:#eef1f6;">
    <div style="max-width:1240px;margin:0 auto;">
      <div style="font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:0.2em;color:#1b355e;margin-bottom:20px;">ALL VIDEOS</div>
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:24px;">
        {lib.map((v, i) => (
          <div class="vid-card" data-idx={i} style={`cursor:pointer;background:var(--surface);border:1px solid ${i === 0 ? 'var(--accent)' : 'var(--line)'};`}>
            <div style={`position:relative;width:100%;aspect-ratio:16/9;background-image:url('${thumb(v.id)}');background-size:cover;background-position:center;`}>
              <div style="position:absolute;inset:0;background:linear-gradient(180deg,transparent,rgba(10,22,38,0.55));"></div>
              <div style="position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);width:52px;height:52px;border-radius:50%;background:rgba(254,238,0,0.95);display:flex;align-items:center;justify-content:center;box-shadow:0 4px 16px rgba(0,0,0,0.3);">
                <div style="width:0;height:0;border-left:17px solid #0a1626;border-top:10px solid transparent;border-bottom:10px solid transparent;margin-left:3px;"></div>
              </div>
            </div>
            <div style="padding:16px 18px;">
              <div style="font-family:'IBM Plex Mono',monospace;font-size:9.5px;letter-spacing:0.1em;color:#1b355e;margin-bottom:6px;">{v.tag}</div>
              <div style="font-family:'Archivo',sans-serif;font-weight:700;font-size:15px;color:#0f2240;line-height:1.25;margin-bottom:8px;">{v.title}</div>
              <div style="font-size:12.5px;color:#5f676e;line-height:1.5;">{v.desc}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TOPIC EXPLAINERS -->
  <section style="padding:48px 32px 56px;background:#eef1f6;">
    <div style="max-width:1240px;margin:0 auto;">
      <div style="font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:0.2em;color:#1b355e;margin:28px 0 18px;">WHAT YOU'LL FIND ON THE CHANNEL</div>
      <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:#d9dfe9;border:1px solid #d9dfe9;">
        {topics.map((t) => (
          <div style="background:#fff;padding:24px 22px;">
            <div style="font-family:'Archivo',sans-serif;font-weight:800;font-size:18px;color:#1b355e;margin-bottom:8px;">{t.t}</div>
            <div style="font-size:13px;color:#5f676e;line-height:1.55;">{t.b}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- NEWSLETTER CTA -->
  <section style="padding:0 32px 80px;background:#eef1f6;">
    <div style="max-width:1240px;margin:0 auto;">
      <div style="background:#0f2240;color:#eef1f6;padding:36px 40px;display:flex;justify-content:space-between;align-items:center;gap:30px;flex-wrap:wrap;">
        <div>
          <div style="font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:0.14em;color:#feee00;margin-bottom:10px;">STAY AHEAD OF THE WELL</div>
          <h2 style="font-family:'Archivo',sans-serif;font-weight:800;font-size:24px;letter-spacing:-0.01em;margin:0;max-width:34ch;">New videos and technical guides — in your inbox.</h2>
        </div>
        <form data-feasibility style="display:flex;gap:10px;flex-wrap:wrap;align-items:flex-start;">
          <input class="gx-field" type="email" name="email" placeholder="your work email" required style="min-width:240px;width:auto;" />
          <button class="gx-submit" type="submit" style="width:auto;padding:13px 22px;font-size:14px;">Subscribe</button>
          <p data-form-status style="font-size:11.5px;color:#8493ac;margin:0;width:100%;"></p>
        </form>
      </div>
    </div>
  </section>

  <SiteFooter />
</Layout>

<script define:vars={{ lib }}>
  const frame = document.getElementById('vid-frame');
  const rows = [...document.querySelectorAll('.vid-row')];
  const cards = [...document.querySelectorAll('.vid-card')];
  let activeIdx = 0;

  function thumb(id) { return `https://i.ytimg.com/vi/${id}/hqdefault.jpg`; }
  function embed(id) { return `https://www.youtube-nocookie.com/embed/${id}?autoplay=1&rel=0&modestbranding=1`; }

  function renderFacade() {
    const v = lib[activeIdx];
    frame.innerHTML =
      `<div id="vid-facade" data-video-facade data-embed="${embed(v.id)}" data-title="${v.title.replace(/"/g, '&quot;')}" style="position:absolute;inset:0;cursor:pointer;background-image:url('${thumb(v.id)}');background-size:cover;background-position:center;">
        <div style="position:absolute;inset:0;background:linear-gradient(180deg,rgba(10,22,38,0.1),rgba(10,22,38,0.65));"></div>
        <div style="position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);width:84px;height:84px;border-radius:50%;background:#feee00;display:flex;align-items:center;justify-content:center;box-shadow:0 8px 30px rgba(0,0,0,0.35);">
          <div style="width:0;height:0;border-left:26px solid #0a1626;border-top:16px solid transparent;border-bottom:16px solid transparent;margin-left:6px;"></div>
        </div>
      </div>`;
  }

  function select(i) {
    activeIdx = i;
    const v = lib[i];
    document.getElementById('vid-tag').textContent = v.tag;
    document.getElementById('vid-title').textContent = v.title;
    document.getElementById('vid-desc').textContent = v.desc;
    rows.forEach((r, j) => {
      r.style.background = j === i ? 'var(--surface)' : 'transparent';
      r.style.borderColor = j === i ? 'var(--accent)' : 'var(--line)';
    });
    cards.forEach((c, j) => { c.style.borderColor = j === i ? 'var(--accent)' : 'var(--line)'; });
    renderFacade();
  }

  function play() {
    const v = lib[activeIdx];
    const iframe = document.createElement('iframe');
    iframe.src = embed(v.id);
    iframe.title = v.title;
    iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share';
    iframe.allowFullscreen = true;
    iframe.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;border:0;';
    frame.innerHTML = '';
    frame.appendChild(iframe);
  }

  frame.addEventListener('click', (e) => { if (e.target.closest('#vid-facade')) play(); });
  rows.forEach((r) => r.addEventListener('click', () => select(+r.dataset.idx)));
  cards.forEach((c) => c.addEventListener('click', () => { select(+c.dataset.idx); window.scrollTo({ top: 0, behavior: 'smooth' }); }));
</script>

<script>
  import '../scripts/forms.js';
</script>

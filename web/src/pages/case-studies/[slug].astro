---
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import { url } from '../../lib/links.js';
import { caseStudies, caseImage } from '../../data/case-studies.js';

export async function getStaticPaths() {
  return caseStudies.map((c) => ({ params: { slug: c.slug }, props: { c } }));
}

const { c } = Astro.props;
const others = caseStudies.filter((x) => x.slug !== c.slug && x.featured).slice(0, 3);
const detailed = !!c.challenge;
const heroImg = caseImage(c);
---
<Layout title={`${c.client} — ${c.location} | Case Study | Gunnar Energy Services`} description={c.title}>
  <SiteHeader />

  <!-- HERO -->
  <section class="dotgrid" style="position:relative;background:var(--ground-2);border-bottom:1px solid var(--line);overflow:hidden;min-height:62vh;display:flex;align-items:flex-end;">
    <div class="cine" style="position:absolute;inset:0;">
      <img src={url(heroImg)} alt={`${c.client} — ${c.location}`} />
    </div>
    <div class="wrap" style="position:relative;padding-top:clamp(48px,9vh,96px);padding-bottom:clamp(40px,6vh,72px);">
      <div style="font-family:var(--mono);font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:var(--text-faint);margin-bottom:26px;">
        <a href={url('/')} style="color:var(--text-faint);">Home</a> &nbsp;/&nbsp;
        <a href={url('/case-studies/')} style="color:var(--text-faint);">Case Studies</a> &nbsp;/&nbsp;
        <span style="color:var(--accent);">{c.client}</span>
      </div>
      <div class="kicker-row" style="margin-bottom:22px;"><span class="eyebrow">{c.scope.join(' · ')}</span></div>
      <h1 class="display d-l" data-reveal style="max-width:24ch;">{c.client}</h1>
      <div style="font-family:var(--mono);font-size:13px;letter-spacing:0.06em;color:var(--text-dim);margin-top:18px;">{c.location} &nbsp;·&nbsp; {c.year}</div>
      <p class="lede" data-reveal style="max-width:64ch;margin-top:20px;color:var(--text);">{c.title}</p>
    </div>
  </section>

  {detailed ? (
    <>
      <!-- CHALLENGE + SOLUTION -->
      <section class="section">
        <div class="wrap" style="display:grid;grid-template-columns:1fr 1fr;gap:64px;">
          <div data-reveal>
            <div class="kicker-row" style="margin-bottom:24px;"><span class="eyebrow">The challenge</span></div>
            <ul style="margin:0;padding:0;list-style:none;">
              {c.challenge.map((p) => (
                <li style="font-size:15.5px;line-height:1.6;color:var(--text-dim);padding:14px 0;border-top:1px solid var(--line);display:flex;gap:12px;"><span style="color:var(--accent);flex:none;">—</span>{p}</li>
              ))}
            </ul>
          </div>
          <div data-reveal style="border-left:1px solid var(--line);padding-left:48px;">
            <div class="kicker-row" style="margin-bottom:24px;"><span class="eyebrow">Our solution</span></div>
            <p style="font-size:16px;line-height:1.75;color:var(--text);margin:0 0 22px;">{c.solution}</p>
            {c.outcome && (
              <div style="background:var(--accent);color:#0A0C0F;padding:16px 20px;font-size:14px;font-weight:600;">{c.outcome}</div>
            )}
          </div>
        </div>
      </section>

      <!-- RESULT -->
      <section class="section" style="background:var(--ground-2);border-top:1px solid var(--line);">
        <div class="wrap" style="display:grid;grid-template-columns:0.8fr 1.2fr;gap:64px;align-items:center;">
          <div data-reveal>
            <div class="kicker-row" style="margin-bottom:24px;"><span class="eyebrow">The result</span></div>
            <div class="display d-l" style="color:var(--accent);">{c.result.metric}</div>
            <div class="muted" style="font-size:14px;margin-top:10px;max-width:24ch;">{c.result.metricLabel}</div>
          </div>
          <ul data-reveal style="margin:0;padding:0;list-style:none;">
            {c.result.points.map((p) => (
              <li style="font-size:15.5px;line-height:1.6;color:var(--text-dim);padding:16px 0;border-top:1px solid var(--line);display:flex;gap:12px;"><span style="color:var(--accent);flex:none;">·</span>{p}</li>
            ))}
          </ul>
        </div>
      </section>
    </>
  ) : (
    <!-- TRACK-RECORD ENTRY (write-up in preparation) -->
    <section class="section">
      <div class="wrap" style="max-width:820px;">
        <div class="kicker-row" data-reveal style="margin-bottom:28px;"><span class="eyebrow">Project summary</span></div>
        <p class="lede" data-reveal style="color:var(--text);">{c.title}.</p>
        <p data-reveal style="font-size:15.5px;line-height:1.7;color:var(--text-dim);margin:20px 0 0;">
          This project is part of Gunnar's documented track record. A detailed write-up is in
          preparation — for specifics on scope, ranging methodology and outcomes, get in touch and
          a ranging engineer will walk you through it.
        </p>
        <div style="margin-top:28px;"><a href={url('/contact/')} class="btn btn-primary">Ask about this project</a></div>
      </div>
    </section>
  )}

  <!-- PROJECT META -->
  <section class="section" style={detailed ? '' : 'background:var(--ground-2);border-top:1px solid var(--line);'}>
    <div class="wrap">
      <div class="hgrid" style="grid-template-columns:repeat(auto-fit,minmax(200px,1fr));" data-reveal>
        {[['Ranging', c.meta.ranging], ['Deployment', c.meta.deployment], ['Re-entry', c.meta.reentry], ['Location', c.location], ['Year', c.year]].map(([k, v]) => (
          <div style="padding:24px;background:var(--ground);">
            <div class="eyebrow eyebrow--dim" style="margin-bottom:10px;">{k}</div>
            <div style="font-size:15px;color:var(--text);font-weight:600;">{v}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- MORE CASES -->
  <section class="section" style="background:var(--ground-2);border-top:1px solid var(--line);">
    <div class="wrap">
      <div class="kicker-row" data-reveal style="margin-bottom:36px;"><span class="eyebrow">More case studies</span></div>
      <div class="hgrid" style="grid-template-columns:repeat(3,1fr);" data-reveal>
        {others.map((o) => (
          <a href={url('/case-studies/' + o.slug + '/')} class="tile tile--link" style="padding:28px 24px;background:var(--ground);">
            <div class="eyebrow eyebrow--dim" style="margin-bottom:12px;">{o.scope[0]}</div>
            <div class="h-card" style="font-size:19px;color:var(--text);margin-bottom:6px;">{o.client}</div>
            <div class="faint" style="font-size:12px;margin-bottom:12px;">{o.location} · {o.year}</div>
            <span style="font-family:var(--mono);font-size:11px;letter-spacing:0.1em;text-transform:uppercase;color:var(--accent);">Read →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <SiteFooter />
</Layout>

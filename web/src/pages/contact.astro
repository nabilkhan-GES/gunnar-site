---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';

const contacts = [
  { k: '24/7 EMERGENCY', v: '+1 832 555 0100', sub: 'Active well-control & blowout response' },
  { k: 'GENERAL ENQUIRIES', v: 'info@gunnarenergyservices.com', sub: 'Project scoping, partnerships, careers' },
  { k: 'HEADQUARTERS', v: 'Bakersfield, California', sub: 'With operations in Texas & Australia' },
];
const apps = ['Relief well', 'Plug & abandonment', 'CCUS', 'Geothermal', 'Solution mining', 'Well re-entry'];
const offices = [
  { city: 'Bakersfield, CA', tag: 'GLOBAL HEADQUARTERS', addr: 'Engineering, R&D and operations base for North American projects.' },
  { city: 'Texas', tag: 'GULF COAST OPERATIONS', addr: 'Well-control and intervention support for Gulf Coast and onshore basins.' },
  { city: 'Australia', tag: 'ASIA-PACIFIC', addr: 'Regional operations supporting projects across the Asia-Pacific region.' },
];
---
<Layout title="Contact — Request a Feasibility Review | Gunnar Energy Services" description="Tell us about the well — geometry, access and timeline — and a ranging engineer will scope a deterministic intercept plan. 24/7 emergency well-control line available.">
  <SiteHeader />

  <!-- EMERGENCY STRIP -->
  <section style="background:#feee00;color:#0a1626;padding:18px 32px;">
    <div style="max-width:1240px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;gap:20px;flex-wrap:wrap;">
      <div style="display:flex;align-items:center;gap:12px;">
        <span style="display:inline-block;width:9px;height:9px;border-radius:50%;background:#0a1626;"></span>
        <span style="font-family:'Archivo',sans-serif;font-weight:800;font-size:16px;letter-spacing:0.01em;">ACTIVE WELL-CONTROL EMERGENCY? CALL NOW — 24/7 RESPONSE.</span>
      </div>
      <a href="tel:+18325550100" style="background:#0a1626;color:#feee00;font-family:'IBM Plex Mono',monospace;font-weight:600;font-size:14px;padding:10px 18px;border-radius:3px;">+1 832 555 0100 →</a>
    </div>
  </section>

  <section style="padding:72px 32px;background:#0f2240;color:#eef1f6;position:relative;overflow:hidden;">
    <div style="position:absolute;top:-160px;right:-120px;width:460px;height:460px;border-radius:50%;border:1px solid rgba(254,238,0,0.14);"></div>
    <div style="max-width:1240px;margin:0 auto;position:relative;display:grid;grid-template-columns:1fr 1fr;gap:56px;align-items:start;">
      <div>
        <div style="font-family:'IBM Plex Mono',monospace;font-size:12.5px;letter-spacing:0.18em;color:#feee00;margin-bottom:18px;">LET'S TALK</div>
        <h1 style="font-family:'Archivo',sans-serif;font-weight:900;font-size:46px;line-height:1.02;letter-spacing:-0.025em;margin:0 0 22px;max-width:16ch;">Tell us about the well.</h1>
        <p style="font-size:18px;line-height:1.6;color:#c3cee0;max-width:46ch;margin:0 0 36px;">Share the geometry, access and timeline, and a ranging engineer will scope a deterministic intercept plan. For active well-control emergencies, call the 24/7 line above.</p>
        <div style="display:grid;gap:22px;">
          {contacts.map((c) => (
            <div style="border-top:1px solid rgba(255,255,255,0.14);padding-top:16px;">
              <div style="font-family:'IBM Plex Mono',monospace;font-size:10.5px;letter-spacing:0.14em;color:#8493ac;margin-bottom:6px;">{c.k}</div>
              <div style="font-size:16px;color:#eef1f6;font-weight:600;">{c.v}</div>
              <div style="font-size:13.5px;color:#8493ac;margin-top:2px;">{c.sub}</div>
            </div>
          ))}
        </div>
      </div>
      <div style="background:#14294a;border:1px solid rgba(255,255,255,0.1);padding:34px;">
        <div style="font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:0.12em;color:#feee00;margin-bottom:20px;">REQUEST A FEASIBILITY REVIEW</div>
        <form data-feasibility style="display:grid;gap:14px;">
          <div>
            <div style="font-size:12px;color:#8493ac;margin-bottom:6px;">Full name</div>
            <input class="gx-field" type="text" name="name" placeholder="Jane Engineer" required />
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
            <div><div style="font-size:12px;color:#8493ac;margin-bottom:6px;">Company</div><input class="gx-field" type="text" name="company" placeholder="Operator Inc." /></div>
            <div><div style="font-size:12px;color:#8493ac;margin-bottom:6px;">Work email</div><input class="gx-field" type="email" name="email" placeholder="jane@operator.com" required /></div>
          </div>
          <div>
            <div style="font-size:12px;color:#8493ac;margin-bottom:6px;">Application</div>
            <div style="display:flex;flex-wrap:wrap;gap:8px;">
              {apps.map((a) => (
                <label class="gx-chip-radio">
                  <input type="radio" name="application" value={a} />
                  <span style="display:inline-block;font-size:12px;font-family:'IBM Plex Mono',monospace;color:#c3cee0;background:#0a1626;border:1px solid rgba(255,255,255,0.14);padding:7px 11px;border-radius:2px;transition:all .12s ease;">{a}</span>
                </label>
              ))}
            </div>
          </div>
          <div>
            <div style="font-size:12px;color:#8493ac;margin-bottom:6px;">Well details &amp; timeline</div>
            <textarea class="gx-field" name="details" placeholder="Target depth, geometry, access constraints, timeline…" style="height:90px;"></textarea>
          </div>
          <button class="gx-submit" type="submit">Submit request</button>
          <p data-form-status style="font-size:11.5px;color:#8493ac;margin:2px 0 0;text-align:center;line-height:1.5;">We typically respond within one business day. Emergencies: call the 24/7 line.</p>
        </form>
      </div>
    </div>
  </section>

  <section style="padding:64px 32px;background:#fff;border-bottom:1px solid #d9dfe9;">
    <div style="max-width:1240px;margin:0 auto;">
      <div style="font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:0.2em;color:#1b355e;margin-bottom:22px;">OPERATING LOCATIONS</div>
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:24px;">
        {offices.map((o) => (
          <div style="border:1px solid #d9dfe9;padding:26px;">
            <div style="font-family:'Archivo',sans-serif;font-weight:700;font-size:19px;color:#0f2240;margin-bottom:6px;">{o.city}</div>
            <div style="font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:0.06em;color:#1b355e;margin-bottom:12px;">{o.tag}</div>
            <p style="font-size:13.5px;color:#5f676e;line-height:1.55;margin:0;">{o.addr}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <SiteFooter />
</Layout>

<script>
  import '../scripts/forms.js';
</script>

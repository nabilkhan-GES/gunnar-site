---
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import { url } from '../../lib/links.js';

export async function getStaticPaths() {
  const mods = import.meta.glob('../../data/services/*.json', { eager: true });
  return Object.values(mods).map((m) => {
    const s = m.default;
    return { params: { slug: s.slug }, props: { s } };
  });
}

const { s } = Astro.props;
---
<Layout title={`${s.crumb} | Gunnar Energy Services`} description={s.intro}>
  <SiteHeader />

  <!-- HERO -->
  <section style="background:#0f2240;color:#eef1f6;position:relative;overflow:hidden;padding:64px 32px 72px;">
    <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(255,255,255,0.045) 1px,transparent 1px);background-size:28px 28px;opacity:0.6;"></div>
    <div style="position:absolute;top:-180px;right:-140px;width:520px;height:520px;border-radius:50%;border:1px solid rgba(254,238,0,0.14);"></div>
    <div style="max-width:1240px;margin:0 auto;position:relative;">
      <div style="font-family:'IBM Plex Mono',monospace;font-size:11.5px;letter-spacing:0.08em;color:#8493ac;margin-bottom:24px;"><a href={url('/')} style="color:#8493ac;">Home</a> &nbsp;/&nbsp; <a href={url('/services/')} style="color:#8493ac;">Services</a> &nbsp;/&nbsp; <span style="color:#feee00;">{s.crumb}</span></div>
      <div style="font-family:'IBM Plex Mono',monospace;font-size:12.5px;letter-spacing:0.18em;color:#feee00;margin-bottom:18px;">{s.tag}</div>
      <h1 style="font-family:'Archivo',sans-serif;font-weight:900;font-size:52px;line-height:1.02;letter-spacing:-0.025em;margin:0 0 22px;max-width:18ch;">{s.title}</h1>
      <p style="font-size:19px;line-height:1.55;color:#c3cee0;max-width:60ch;margin:0 0 32px;">{s.intro}</p>
      <div style="display:flex;gap:14px;flex-wrap:wrap;margin-bottom:44px;">
        <a href={url('/contact/')} style="background:#feee00;color:#0a1626;font-weight:700;font-size:15px;padding:15px 26px;border-radius:3px;">{s.ctaLabel}</a>
        <a href="tel:+18325550100" style="border:1px solid rgba(255,255,255,0.28);color:#eef1f6;font-weight:600;font-size:15px;padding:15px 26px;border-radius:3px;">24/7 Emergency line →</a>
      </div>
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:rgba(255,255,255,0.12);border:1px solid rgba(255,255,255,0.12);max-width:680px;">
        {s.heroStats.map((st) => (
          <div style="background:#0f2240;padding:18px 20px;">
            <div style="font-family:'Archivo',sans-serif;font-weight:800;font-size:26px;color:#feee00;line-height:1;">{st.n}</div>
            <div style="font-size:12px;color:#8493ac;margin-top:7px;line-height:1.3;">{st.l}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CHALLENGE + APPROACH -->
  <section style="padding:80px 32px;background:#fff;border-bottom:1px solid #d9dfe9;">
    <div style="max-width:1240px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:56px;">
      <div>
        <div style="font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:0.16em;color:#1b355e;margin-bottom:14px;">THE CHALLENGE</div>
        <h2 style="font-family:'Archivo',sans-serif;font-weight:700;font-size:28px;letter-spacing:-0.01em;line-height:1.15;margin:0 0 18px;">{s.challengeTitle}</h2>
        {s.challenge.map((p) => <p style="font-size:15.5px;line-height:1.65;color:#454c52;margin:0 0 16px;">{p}</p>)}
      </div>
      <div style="background:#f5f7fb;border-left:3px solid #feee00;padding:34px;">
        <div style="font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:0.16em;color:#1b355e;margin-bottom:14px;">THE GUNNAR APPROACH</div>
        <h2 style="font-family:'Archivo',sans-serif;font-weight:700;font-size:28px;letter-spacing:-0.01em;line-height:1.15;margin:0 0 18px;">{s.approachTitle}</h2>
        {s.approach.map((p) => <p style="font-size:15.5px;line-height:1.65;color:#454c52;margin:0 0 16px;">{p}</p>)}
      </div>
    </div>
  </section>

  <!-- CAPABILITIES -->
  <section style="padding:80px 32px;background:#eef1f6;">
    <div style="max-width:1240px;margin:0 auto;">
      <div style="font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:0.2em;color:#1b355e;margin-bottom:14px;">SCOPE OF WORK — ONE INTEGRATED TEAM</div>
      <h2 style="font-family:'Archivo',sans-serif;font-weight:800;font-size:34px;letter-spacing:-0.02em;margin:0 0 36px;">{s.capTitle}</h2>
      <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:1px;background:#d9dfe9;border:1px solid #d9dfe9;">
        {s.capabilities.map((c) => (
          <div style="background:#fff;padding:22px 26px;display:flex;gap:16px;align-items:flex-start;">
            <span style="color:#1b355e;font-family:'Archivo',sans-serif;font-weight:800;font-size:14px;flex:none;margin-top:2px;">{c.n}</span>
            <div>
              <div style="font-weight:700;font-size:16px;color:#0f2240;margin-bottom:5px;">{c.t}</div>
              <div style="font-size:14px;color:#5f676e;line-height:1.55;">{c.b}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TECHNOLOGY DEPLOYED -->
  <section style="padding:80px 32px;background:#0f2240;color:#eef1f6;">
    <div style="max-width:1240px;margin:0 auto;">
      <div style="display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:16px;margin-bottom:34px;">
        <div>
          <div style="font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:0.2em;color:#feee00;margin-bottom:14px;">TECHNOLOGY DEPLOYED</div>
          <h2 style="font-family:'Archivo',sans-serif;font-weight:800;font-size:34px;letter-spacing:-0.02em;margin:0;color:#eef1f6;">Proprietary tools for this application.</h2>
        </div>
        <a href={url('/technology/')} style="color:#feee00;font-weight:600;font-size:15px;">Explore the full portfolio →</a>
      </div>
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:rgba(255,255,255,0.12);border:1px solid rgba(255,255,255,0.12);">
        {s.tech.map((t) => (
          <a href={url('/technology/')} class="hov-bg-navy" style="background:#0f2240;padding:26px 22px;display:block;">
            <div style="font-family:'Archivo',sans-serif;font-weight:700;font-size:20px;color:#feee00;margin-bottom:10px;">{t.name}</div>
            <div style="font-size:13.5px;color:#c3cee0;line-height:1.55;">{t.note}</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CASE STUDY -->
  <section style="padding:80px 32px;background:#fff;border-bottom:1px solid #d9dfe9;">
    <div style="max-width:1240px;margin:0 auto;display:grid;grid-template-columns:1fr 1.1fr;gap:48px;align-items:center;">
      <div style="height:300px;background:#102444;background-image:repeating-linear-gradient(135deg,rgba(255,255,255,0.05) 0 11px,transparent 11px 22px);position:relative;display:flex;align-items:flex-end;padding:20px;">
        <span style="position:absolute;top:18px;left:20px;font-family:'IBM Plex Mono',monospace;font-size:10px;color:#5b6a85;">[ {s.caseImg} ]</span>
        <span style="font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:0.1em;color:#feee00;">{s.caseScope}</span>
      </div>
      <div>
        <div style="font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:0.16em;color:#1b355e;margin-bottom:14px;">PROOF — CASE STUDY</div>
        <h2 style="font-family:'Archivo',sans-serif;font-weight:800;font-size:30px;letter-spacing:-0.02em;margin:0 0 6px;">{s.caseTitle}</h2>
        <div style="font-size:13.5px;color:#8493ac;margin-bottom:18px;">{s.caseLoc}</div>
        <p style="font-size:15.5px;line-height:1.65;color:#454c52;margin:0 0 22px;">{s.caseBody}</p>
        <div style="display:flex;gap:36px;flex-wrap:wrap;align-items:flex-end;">
          <div><div style="font-family:'Archivo',sans-serif;font-weight:800;font-size:32px;color:#1b355e;line-height:1;">{s.caseMetric}</div><div style="font-size:13px;color:#5f676e;margin-top:5px;">{s.caseMetricL}</div></div>
          <a href={url('/case-studies/')} style="color:#1b355e;font-weight:600;font-size:15px;">All case studies →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section style="padding:80px 32px;background:#eef1f6;">
    <div style="max-width:920px;margin:0 auto;">
      <div style="font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:0.2em;color:#1b355e;margin-bottom:14px;">FREQUENTLY ASKED</div>
      <h2 style="font-family:'Archivo',sans-serif;font-weight:800;font-size:32px;letter-spacing:-0.02em;margin:0 0 32px;">{s.crumb} — your questions, answered.</h2>
      {s.faqs.map((f) => (
        <div style="border-top:1px solid #d2d9e4;padding:22px 0;">
          <h3 style="font-family:'Archivo',sans-serif;font-weight:700;font-size:18px;margin:0 0 9px;color:#0f2240;">{f.q}</h3>
          <p style="font-size:15px;line-height:1.65;color:#454c52;margin:0;">{f.a}</p>
        </div>
      ))}
    </div>
  </section>

  <SiteFooter />
</Layout>

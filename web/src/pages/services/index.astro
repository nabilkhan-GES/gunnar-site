---
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import { url } from '../../lib/links.js';

const services = [
  { idx: '01', tag: 'WELL CONTROL', kw: 'Relief Well & Blowout Intercept', desc: 'Deterministic intercept and kill when surface control has failed — planned and emergency response, ranged and drilled to inch-level accuracy.', chips: ['Blowout response', 'Active ranging', 'Well kill'], cta: 'Explore relief wells', href: '/services/relief-wells/' },
  { idx: '02', tag: 'DECOMMISSIONING', kw: 'Plug & Abandonment', desc: 'No-access ranging that seals complex, legacy and inaccessible wells — cutting typical rig time by 50% or more.', chips: ['No-access P&A', 'Urban & offshore', 'CalGEM-certified'], cta: 'Explore P&A', href: '/services/plug-and-abandonment/' },
  { idx: '03', tag: 'ENERGY TRANSITION', kw: 'CCUS Well Integrity', desc: 'Locate, seal and verify every well in a carbon-storage complex — relief-well-grade integrity for MRV-ready storage.', chips: ['Zonal isolation', 'Legacy wells', 'MRV support'], cta: 'Explore CCUS', href: '/services/ccus/' },
  { idx: '04', tag: 'ENERGY TRANSITION', kw: 'Geothermal Well Placement', desc: 'Intersect and space wellbores precisely for closed-loop and enhanced geothermal — the hardest part of the well design.', chips: ['Closed-loop', 'Well intersection', 'Reservoir spacing'], cta: 'Explore geothermal', href: '/services/geothermal/' },
  { idx: '05', tag: 'MINING', kw: 'Solution Mining Connections', desc: 'Precise wellbore intersection and spacing for in-situ recovery of potash, lithium, uranium and other minerals.', chips: ['Well connection', 'Field spacing', 'Critical minerals'], cta: 'Explore solution mining', href: '/services/solution-mining/' },
  { idx: '06', tag: 'WELL INTERVENTION', kw: 'Well Re-Entry & Milling', desc: 'Range, mill and re-enter wells with damaged casing, stuck packers or lost access — outside-in, often under pressure.', chips: ['Outside-in milling', 'Below-fish', 'High-inclination'], cta: 'Explore re-entry', href: '/services/well-re-entry/' },
];
const chain = [
  { n: '01', t: 'Engineering & planning' },
  { n: '02', t: 'Active magnetic ranging' },
  { n: '03', t: 'Directional drilling' },
  { n: '04', t: 'Milling & re-entry' },
  { n: '05', t: 'Well kill & control' },
  { n: '06', t: 'Cement & abandonment' },
];
---
<Layout title="Services — Wellbore Positioning & Intervention | Gunnar Energy Services" description="From emergency relief wells to complex abandonment, CCUS and geothermal placement — one core capability, delivered end-to-end by one accountable team.">
  <SiteHeader />

  <section style="background:#0f2240;color:#eef1f6;position:relative;overflow:hidden;padding:64px 32px 70px;">
    <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(255,255,255,0.045) 1px,transparent 1px);background-size:28px 28px;opacity:0.6;"></div>
    <div style="position:absolute;top:-180px;right:-140px;width:520px;height:520px;border-radius:50%;border:1px solid rgba(254,238,0,0.14);"></div>
    <div style="max-width:1240px;margin:0 auto;position:relative;">
      <div style="font-family:'IBM Plex Mono',monospace;font-size:11.5px;letter-spacing:0.08em;color:#8493ac;margin-bottom:24px;"><a href={url('/')} style="color:#8493ac;">Home</a> &nbsp;/&nbsp; <span style="color:#feee00;">Services</span></div>
      <div style="font-family:'IBM Plex Mono',monospace;font-size:12.5px;letter-spacing:0.18em;color:#feee00;margin-bottom:18px;">WELLBORE POSITIONING &amp; INTERVENTION</div>
      <h1 style="font-family:'Archivo',sans-serif;font-weight:900;font-size:54px;line-height:1.02;letter-spacing:-0.025em;margin:0 0 22px;max-width:20ch;">One discipline. Every well that has to be hit.</h1>
      <p style="font-size:19px;line-height:1.55;color:#c3cee0;max-width:64ch;margin:0;">From emergency relief wells to complex abandonment and the wells of the energy transition, Gunnar applies a single core capability — precise, deterministic wellbore placement — across every application. Each service is delivered end-to-end by one accountable team.</p>
    </div>
  </section>

  <section style="padding:72px 32px;background:#eef1f6;">
    <div style="max-width:1240px;margin:0 auto;display:grid;grid-template-columns:repeat(2,1fr);gap:24px;">
      {services.map((s) => (
        <a href={url(s.href)} class="hov-border-navy" style="background:#fff;border:1px solid #d9dfe9;padding:34px;display:flex;flex-direction:column;min-height:240px;">
          <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:16px;">
            <span style="font-family:'IBM Plex Mono',monospace;font-size:10.5px;letter-spacing:0.12em;color:#1b355e;">{s.tag}</span>
            <span style="font-family:'IBM Plex Mono',monospace;font-size:11px;color:#8493ac;">{s.idx}</span>
          </div>
          <h2 style="font-family:'Archivo',sans-serif;font-weight:700;font-size:25px;line-height:1.12;margin:0 0 12px;color:#0f2240;">{s.kw}</h2>
          <p style="font-size:15px;color:#5f676e;line-height:1.6;margin:0 0 20px;flex:1;">{s.desc}</p>
          <div style="display:flex;flex-wrap:wrap;gap:8px;margin-bottom:18px;">
            {s.chips.map((ch) => <span style="font-size:11.5px;font-family:'IBM Plex Mono',monospace;color:#1b355e;background:#eef1f6;border:1px solid #d9dfe9;padding:4px 9px;border-radius:2px;">{ch}</span>)}
          </div>
          <span style="font-size:14px;font-weight:600;color:#1b355e;">{s.cta} →</span>
        </a>
      ))}
    </div>
  </section>

  <section style="padding:80px 32px;background:#fff;border-top:1px solid #d9dfe9;">
    <div style="max-width:1240px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:56px;align-items:center;">
      <div>
        <div style="font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:0.2em;color:#1b355e;margin-bottom:14px;">WHY IT'S ONE TEAM</div>
        <h2 style="font-family:'Archivo',sans-serif;font-weight:800;font-size:34px;letter-spacing:-0.02em;line-height:1.12;margin:0 0 18px;">No handoffs between the people who plan it and the people who do it.</h2>
        <p style="font-size:16px;line-height:1.65;color:#454c52;margin:0 0 16px;">Traditional projects split engineering, ranging, drilling, milling and kill across multiple vendors — each with its own incentives and gaps. Gunnar owns the whole chain, so accountability never changes hands.</p>
        <a href={url('/contact/')} style="color:#1b355e;font-weight:600;font-size:15px;">Talk to a ranging engineer →</a>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:1px;background:#d9dfe9;border:1px solid #d9dfe9;">
        {chain.map((c) => (
          <div style="background:#f5f7fb;padding:22px 20px;"><div style="font-family:'Archivo',sans-serif;font-weight:800;font-size:15px;color:#1b355e;margin-bottom:6px;">{c.n}</div><div style="font-size:14px;color:#454c52;">{c.t}</div></div>
        ))}
      </div>
    </div>
  </section>

  <SiteFooter />
</Layout>

---
import Layout from '../../layouts/Layout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import { url } from '../../lib/links.js';

const cats = [
  { label: 'All', active: true },
  { label: 'Relief Wells' }, { label: 'Magnetic Ranging' }, { label: 'Plug & Abandonment' },
  { label: 'CCUS' }, { label: 'Geothermal' }, { label: 'Well Intervention' },
].map((c) => ({
  ...c,
  fg: c.active ? '#0a1626' : '#1b355e',
  bg: c.active ? '#feee00' : '#fff',
  border: c.active ? '#feee00' : '#d9dfe9',
}));

const featured = {
  href: '/insights/relief-wells-101/',
  img: '/assets/banner-relief.png',
  cat: 'RELIEF WELLS',
  read: '8 min read',
  title: 'Relief Wells 101: How Magnetic Ranging Stops a Blowout',
  excerpt: 'When surface control fails, a relief well is the last line of defense. Here\'s how active magnetic ranging turns an impossible target — a well whose exact position is unknown by hundreds of feet — into an inch-perfect intercept and kill.',
};

const posts = [
  { href: '/insights/active-vs-passive-ranging/', img: '/assets/banner-ranging.png', cat: 'MAGNETIC RANGING', read: '6 min', title: 'Active vs. Passive Magnetic Ranging: Which Method for Which Job', excerpt: 'Range, signal strength, rig time and risk — a decision framework for choosing the right ranging method before you spud.' },
  { href: '/insights/pna-cost-reduction/', img: '/assets/banner-pna.png', cat: 'PLUG & ABANDONMENT', read: '7 min', title: 'How to Cut P&A Costs by 50% with No-Access Ranging', excerpt: 'Where the savings actually come from when you replace open-hole wireline runs with ranging-while-drilling on complex abandonment.' },
  { href: '/insights/ranging-while-drilling/', img: '/assets/banner-ranging.png', cat: 'MAGNETIC RANGING', read: '5 min', title: 'Ranging-While-Drilling: Eliminating the Wireline Round-Trip', excerpt: 'Why continuous ranging from the BHA shortens the critical path to intercept — and what wired pipe makes possible.' },
  { href: '/insights/ccus-well-integrity/', img: '/assets/banner-ccus.png', cat: 'CCUS', read: '9 min', title: 'CCUS Well Integrity: Why Ranging Belongs in Your MRV Plan', excerpt: 'A storage site is only as secure as its leakiest well. How to locate, seal and verify legacy wells across a carbon-storage complex.' },
  { href: '/insights/closed-loop-geothermal/', img: '/assets/banner-geo.png', cat: 'GEOTHERMAL', read: '6 min', title: 'Closed-Loop Geothermal: Why Well Intersection Is the Hard Part', excerpt: 'Heat isn\'t the bottleneck — hitting the target is. How proven ranging physics unlocks closed-loop geothermal designs.' },
  { href: '/insights/outside-in-reentry/', img: '/assets/banner-intervention.png', cat: 'WELL INTERVENTION', read: '7 min', title: 'Outside-In Re-Entry: Reaching Wells Everyone Else Gave Up On', excerpt: 'Damaged casing, stuck packers and lost access don\'t have to mean a lost well. How ranging-guided milling restores a path back in.' },
  { href: '/insights/failed-intercept-cost/', img: '/assets/banner-relief.png', cat: 'RELIEF WELLS', read: '5 min', title: 'The True Cost of a Failed Intercept (and How to Avoid It)', excerpt: 'The rig day is the smallest number on the page. A look at what a missed intercept really costs — and the math behind first-time success.' },
  { href: '/insights/offshore-pna/', img: '/assets/banner-pna.png', cat: 'PLUG & ABANDONMENT', read: '6 min', title: 'Offshore P&A: Managing Risk on Aging Infrastructure', excerpt: 'The decommissioning wave is coming. How no-access ranging de-risks rigless abandonment of legacy offshore wells.' },
  { href: '/insights/choosing-a-ranging-provider/', img: '/assets/banner-ranging.png', cat: 'MAGNETIC RANGING', read: '4 min', title: 'Selecting a Ranging Provider: 10 Questions to Ask', excerpt: 'Three numbers every operator should demand, plus the capability gaps that separate a specialist from a side-service.' },
];
---
<Layout title="Insights & Technical Blog | Gunnar Energy Services" description="Plain-language engineering on relief wells, magnetic ranging, plug & abandonment, CCUS and geothermal — written by the people who do the work.">
  <SiteHeader />

  <section style="background:#0f2240;color:#eef1f6;position:relative;overflow:hidden;padding:60px 32px 64px;">
    <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(255,255,255,0.045) 1px,transparent 1px);background-size:28px 28px;opacity:0.6;"></div>
    <div style="position:absolute;top:-180px;right:-140px;width:520px;height:520px;border-radius:50%;border:1px solid rgba(254,238,0,0.14);"></div>
    <div style="max-width:1240px;margin:0 auto;position:relative;">
      <div style="font-family:'IBM Plex Mono',monospace;font-size:11.5px;letter-spacing:0.08em;color:#8493ac;margin-bottom:22px;"><a href={url('/')} style="color:#8493ac;">Home</a> &nbsp;/&nbsp; <span style="color:#feee00;">Insights</span></div>
      <div style="font-family:'IBM Plex Mono',monospace;font-size:12.5px;letter-spacing:0.18em;color:#feee00;margin-bottom:16px;">INSIGHTS &amp; TECHNICAL BLOG</div>
      <h1 style="font-family:'Archivo',sans-serif;font-weight:900;font-size:50px;line-height:1.02;letter-spacing:-0.025em;margin:0 0 18px;max-width:20ch;">The field guide to hitting the target.</h1>
      <p style="font-size:18px;line-height:1.55;color:#c3cee0;max-width:62ch;margin:0;">Plain-language engineering on relief wells, magnetic ranging, plug &amp; abandonment, CCUS and geothermal — written by the people who do the work, for the people who need it done.</p>
    </div>
  </section>

  <section style="padding:28px 32px 8px;background:#eef1f6;">
    <div style="max-width:1240px;margin:0 auto;display:flex;gap:10px;flex-wrap:wrap;">
      {cats.map((c) => (
        <span style={`font-size:12.5px;font-family:'IBM Plex Mono',monospace;letter-spacing:0.04em;color:${c.fg};background:${c.bg};border:1px solid ${c.border};padding:8px 14px;border-radius:2px;`}>{c.label}</span>
      ))}
    </div>
  </section>

  <section style="padding:24px 32px 8px;background:#eef1f6;">
    <div style="max-width:1240px;margin:0 auto;">
      <a href={url(featured.href)} class="hov-border-navy" style="display:grid;grid-template-columns:1.2fr 1fr;gap:0;background:#fff;border:1px solid #d9dfe9;">
        <div style="background:#102444;min-height:320px;position:relative;display:flex;align-items:flex-end;padding:24px;overflow:hidden;">
          <img src={url(featured.img)} alt="" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:0.85;" />
          <span style="position:relative;font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:0.1em;color:#feee00;background:rgba(10,22,38,0.7);padding:5px 10px;">FEATURED ARTICLE</span>
        </div>
        <div style="padding:38px;display:flex;flex-direction:column;justify-content:center;">
          <div style="display:flex;gap:12px;align-items:center;margin-bottom:14px;">
            <span style="font-family:'IBM Plex Mono',monospace;font-size:10.5px;letter-spacing:0.1em;color:#1b355e;">{featured.cat}</span>
            <span style="font-size:12px;color:#8493ac;">{featured.read}</span>
          </div>
          <h2 style="font-family:'Archivo',sans-serif;font-weight:800;font-size:30px;letter-spacing:-0.02em;line-height:1.12;margin:0 0 14px;color:#0f2240;">{featured.title}</h2>
          <p style="font-size:15.5px;line-height:1.65;color:#5f676e;margin:0 0 20px;">{featured.excerpt}</p>
          <span style="font-size:14px;font-weight:600;color:#1b355e;">Read the article →</span>
        </div>
      </a>
    </div>
  </section>

  <section style="padding:32px 32px 80px;background:#eef1f6;">
    <div style="max-width:1240px;margin:0 auto;">
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:24px;">
        {posts.map((p) => (
          <a href={url(p.href)} class="hov-border-navy" style="background:#fff;border:1px solid #d9dfe9;display:flex;flex-direction:column;">
            <div style="height:150px;background:#102444;position:relative;display:flex;align-items:flex-end;padding:14px;overflow:hidden;">
              <img src={url(p.img)} alt="" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:0.85;" />
              <span style="position:relative;font-family:'IBM Plex Mono',monospace;font-size:9.5px;letter-spacing:0.1em;color:#feee00;background:rgba(10,22,38,0.7);padding:4px 9px;">{p.cat}</span>
            </div>
            <div style="padding:24px;display:flex;flex-direction:column;flex:1;">
              <h3 style="font-family:'Archivo',sans-serif;font-weight:700;font-size:18px;line-height:1.2;margin:0 0 10px;color:#0f2240;">{p.title}</h3>
              <p style="font-size:13.5px;color:#5f676e;line-height:1.55;margin:0 0 16px;flex:1;">{p.excerpt}</p>
              <div style="display:flex;justify-content:space-between;align-items:center;border-top:1px solid #eef1f6;padding-top:12px;">
                <span style="font-size:12px;color:#8493ac;">{p.read}</span>
                <span style="font-size:13px;font-weight:600;color:#1b355e;">Read →</span>
              </div>
            </div>
          </a>
        ))}
      </div>

      <div style="margin-top:44px;background:#0f2240;color:#eef1f6;padding:36px 40px;display:flex;justify-content:space-between;align-items:center;gap:30px;flex-wrap:wrap;">
        <div>
          <div style="font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:0.14em;color:#feee00;margin-bottom:10px;">STAY AHEAD OF THE WELL</div>
          <h2 style="font-family:'Archivo',sans-serif;font-weight:800;font-size:24px;letter-spacing:-0.01em;margin:0;max-width:30ch;">Get new technical guides and case studies in your inbox.</h2>
        </div>
        <form data-feasibility style="display:flex;gap:10px;flex-wrap:wrap;align-items:flex-start;">
          <input class="gx-field" type="email" name="email" placeholder="your work email" required style="min-width:240px;width:auto;" />
          <button class="gx-submit" type="submit" style="width:auto;padding:13px 22px;font-size:14px;">Subscribe</button>
          <p data-form-status style="font-size:11.5px;color:#8493ac;margin:0;width:100%;"></p>
        </form>
      </div>
    </div>
  </section>

  <SiteFooter />
</Layout>

<script>
  import '../../scripts/forms.js';
</script>

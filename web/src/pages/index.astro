---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { url } from '../lib/links.js';

const stats = [
  { n: '100%', l: 'intercept success rate' },
  { n: '40+', l: 'projects, 6 countries' },
  { n: '18×', l: 'ranging power vs. wireline' },
  { n: '1 call', l: 'engineering to abandonment' },
];
const logos = ['ExxonMobil', 'Chevron', 'Occidental', 'Woodside', 'Expand Energy', 'SoCalGas', 'Cenovus', 'Devon'];

const pillars = [
  { k: 'PLAN IT', t: 'Engineering', items: ['Complex P&A & relief well planning', 'Wellbore intercept feasibility studies', 'Ranging signal modeling & survey integration', 'Regulatory & risk documentation'] },
  { k: 'BUILD IT', t: 'Technology', items: ['DeadAhead™ wired-pipe AMR-While-Drilling', 'DeadSet™ wireline active ranging', 'CTRWD™ coiled-tubing ranging', 'TopGun™ AI interpretation software'] },
  { k: 'EXECUTE IT', t: 'Field Operations', items: ['Relief well drilling & blowout intercept', 'Well kill & well control', 'Outside-in milling & re-entry', 'Regulator-witnessed permanent P&A'] },
];

const services = [
  { tag: 'WELL CONTROL', kw: 'Relief Well & Blowout Intercept', desc: 'Deterministic intercept and kill when surface control has failed.', cta: 'Emergency response', href: '/services/relief-wells/' },
  { tag: 'P&A', kw: 'Plug & Abandonment', desc: 'No-access ranging that seals complex and legacy wells — cutting rig time up to 50%.', cta: 'Reduce P&A cost', href: '/services/plug-and-abandonment/' },
  { tag: 'RANGING', kw: 'Active Magnetic Ranging', desc: 'The only proven way to deterministically locate and intercept a target wellbore.', cta: 'See methods', href: '/technology/' },
  { tag: 'INTERVENTION', kw: 'Well Re-Entry & Milling', desc: 'Outside-in milling and re-entry of damaged casing, stuck packers and lost-access wells.', cta: 'Learn more', href: '/services/well-re-entry/' },
  { tag: 'ENERGY TRANSITION', kw: 'Geothermal Well Placement', desc: 'Precise intersection and closed-loop connection for next-generation geothermal.', cta: 'Explore', href: '/services/geothermal/' },
  { tag: 'ENERGY TRANSITION', kw: 'CCUS Well Integrity', desc: 'Wellbore placement and integrity assurance for carbon capture and storage.', cta: 'Explore', href: '/services/ccus/' },
  { tag: 'MINING', kw: 'Solution Mining Connections', desc: 'Wellbore intercept for potash, lithium and uranium recovery.', cta: 'Learn more', href: '/services/solution-mining/' },
  { tag: 'UNCONVENTIONAL', kw: 'SAGD & CSG Twinning', desc: 'Precise well twinning, spacing and intercept for enhanced unconventional production.', cta: 'Learn more', href: '/services/' },
];

const rangingUses = [
  { n: '1', t: 'Relief wells & blowouts', b: 'When surface kill has failed, we drill an intercept well that finds and connects with the wild well — then kill it from below.' },
  { n: '2', t: 'Plug & abandonment', b: 'When old wells have damaged casing, stuck packers or lost surface access, we drill a new path that intercepts them for a permanent seal.' },
  { n: '3', t: 'Twinning, avoidance & intercept', b: 'On multi-pad developments we hold precise spacing to prevent frac hits and collisions — and intercept targets for enhanced production.' },
];

const methods = [
  { type: 'ACTIVE · WHILE DRILLING', name: 'DeadAhead™', desc: 'Wired drillpipe for continuous ranging while drilling. 18× more power than wireline. World-first commercial deployment.', range: 'up to 450 ft', best: 'Relief wells, blowout intercepts' },
  { type: 'ACTIVE · WIRELINE', name: 'DeadSet™', desc: 'All-in-one wireline system: AMR + PMR + gyro, rated to 175°C.', range: '100–300 ft', best: 'Relief wells, P&A' },
  { type: 'WHILE DRILLING · COILED TUBING', name: 'CTRWD™', desc: 'First-of-its-kind magnet source + sensor on a coiled-tubing BHA. Ideal where a rig won\'t fit.', range: '~150 ft', best: 'Shallow / urban P&A, ghost wells' },
  { type: 'MAGNETIC SOURCE', name: 'Torped™', desc: 'Downhole rotary magnet generates a strong active field for ranging.', range: '~300 ft', best: 'SAGD twinning, CSG intercept' },
  { type: 'PASSIVE', name: 'EverReady™ PMR', desc: 'Uses existing MWD/GWD data — no extra rig time, no new tools.', range: '~30 ft', best: 'Collision avoidance, SAGD' },
];
const software = [
  { tag: 'AI · RANGING & INTERPRETATION', name: 'TopGun™', desc: 'Web-based suite for automated ranging analysis, 3D visualization and real-time decision support, with a GPT-driven interpretation layer.' },
  { tag: 'INTERCEPT & MILLING', name: 'ClearCut™', desc: 'Precision milling simulation that turns intercept geometry into real-world milling parameters — reducing rig time and operational risk.' },
  { tag: 'AI-DRIVEN PASSIVE RANGING', name: 'EverReady™ Software', desc: 'Non-intrusive ranging from existing MWD/GWD data — fully remote, AI-driven interpretation with proprietary interference processing.' },
];

const deadAhead = [
  { from: '~46 days', fromL: 'Wireline AMR', to: '~32 days', toL: 'AMR-While-Drilling' },
  { from: '20+ runs', fromL: 'Wireline AMR', to: '4 runs', toL: 'AMR-While-Drilling' },
  { from: '~8 A', fromL: 'injection power', to: '18× stronger', toL: 'earlier locate, more margin' },
];

const cases = [
  { imgLabel: 'INTERCEPT OPS', scope: 'INTERCEPT · KILL · P&A · REGULATOR-WITNESSED', client: 'ExxonMobil', loc: 'North Dakota · 2025', body: 'Tubing parted at ~1,000 ft with only a 10 ft window below a stuck packer. DeadAhead™ held 5–10 ft separation over 5,500 ft of continuous ranging — the world\'s first commercial wired-pipe AMR-WD deployment.', metric: '8,642 ft MD', metricL: 'intercepted at exact planned depth · ~$2M saved' },
  { imgLabel: 'BLOWOUT INTERVENTION', scope: 'BLOWOUT · WELL KILL · P&A', client: 'Expand Energy', loc: 'Louisiana · 2025', body: 'An unpermitted 1950s-era legacy well leaked 5,000 bbl/day for 116 days of failed surface intervention. CTRWD™ coiled-tubing ranging located and intercepted the unknown geometry at 1,068 ft MD.', metric: '15 days', metricL: 'to well control vs. 116 days of surface attempts' },
  { imgLabel: 'RELIEF WELL P&A', scope: 'RELIEF WELL P&A · DUAL INTERCEPT', client: 'SoCalGas — Aliso Canyon', loc: 'California · 2020–ongoing', body: 'Relief-well P&A of 1950s-era wells at the site of the largest gas blowout in U.S. history. DeadSet™ AMR and EverReady™ PMR overcame missing surveys and a parasite sidetrack.', metric: '8 intercepts', metricL: 'across a 4-well campaign · regulator-approved' },
];

const diffs = [
  { t: 'Proprietary technology', b: 'DeadAhead™ wired-pipe AMR-WD delivers ~18× the power of wireline ranging — backed by a multi-patent estate and in-house R&D.' },
  { t: 'Proven track record', b: '100% intercept success across 40+ projects, including world-record dual 29,500 ft intercepts. Documented and regulator-witnessed.' },
  { t: 'One integrated call', b: 'Engineering, ranging, directional, milling, kill, cement and abandonment by one accountable team — one contract, one timeline.' },
  { t: 'High barriers to entry', b: 'A proprietary fleet of ranging hardware supercharged by AI — and 140+ combined years of expertise on the highest-stakes wells.' },
];

const faqs = [
  { q: 'What is magnetic ranging?', a: 'Magnetic ranging is a technique that determines the distance and direction from a drilling well to a nearby target wellbore by measuring a magnetic field on the target\'s steel casing. It is the only proven method to deterministically locate and intercept a target well when conventional surveys are too uncertain.' },
  { q: 'What is a relief well?', a: 'A relief well is a separate well drilled to intentionally intersect a blowing or uncontrolled well so it can be killed from below. Modern relief wells use active magnetic ranging to steer to the target with inch-level accuracy at the point of intercept.' },
  { q: 'When do you need active vs. passive ranging?', a: 'Passive ranging (EverReady™) uses the target casing\'s existing magnetism and works at short range with no extra tools. Active ranging (DeadSet™, DeadAhead™) injects a current to generate a strong, controllable signal — essential for longer ranges, relief wells and blowout intercepts.' },
  { q: 'How does ranging reduce plug & abandonment cost?', a: 'No-access ranging-while-drilling eliminates time-consuming wireline round-trips and open-hole exposure. On complex P&A this can save roughly half the rig time and millions of dollars versus conventional wireline methods.' },
  { q: 'Can magnetic ranging be used for CCUS and geothermal?', a: 'Yes. Carbon storage requires verified well integrity and precise placement, and closed-loop geothermal relies on intentionally intersecting two wellbores — both are core ranging applications Gunnar delivers.' },
  { q: 'How accurate is a wellbore intercept?', a: 'With active ranging, accuracy improves as the drilling well homes in on the target — reaching inch-level precision at intercept, even at depths where conventional surveys are off by hundreds of feet.' },
];

const vid = 'iLe8lQrgoWg';
const vidEmbed = `https://www.youtube-nocookie.com/embed/${vid}?autoplay=1&rel=0&modestbranding=1`;
const vidThumb = `https://i.ytimg.com/vi/${vid}/hqdefault.jpg`;
---
<Layout title="Gunnar Energy Services — Relief Wells, Magnetic Ranging & Wellbore Intercept" description="Built for the wells no one else can save. Gunnar is the independent specialist in active magnetic ranging, relief wells, blowout kills, plug & abandonment, CCUS and geothermal placement.">
  <SiteHeader />

  <!-- HERO -->
  <section id="top" style="background:#0f2240;color:#eef1f6;position:relative;overflow:hidden;">
    <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(255,255,255,0.045) 1px,transparent 1px);background-size:28px 28px;opacity:0.7;"></div>
    <div style="position:absolute;top:-220px;right:-180px;width:620px;height:620px;border-radius:50%;border:1px solid rgba(254,238,0,0.16);"></div>
    <div style="position:absolute;top:-140px;right:-100px;width:440px;height:440px;border-radius:50%;border:1px solid rgba(254,238,0,0.12);"></div>
    <div style="max-width:1240px;margin:0 auto;padding:72px 32px 0;position:relative;display:grid;grid-template-columns:1.15fr 0.85fr;gap:56px;align-items:center;">
      <div style="padding-bottom:64px;">
        <div style="font-family:'IBM Plex Mono',monospace;font-size:12.5px;letter-spacing:0.18em;color:#feee00;margin-bottom:22px;">RELIEF WELLS · MAGNETIC RANGING · WELLBORE INTERCEPT</div>
        <h1 style="font-family:'Archivo',sans-serif;font-weight:900;font-size:60px;line-height:1.0;letter-spacing:-0.025em;margin:0 0 24px;">Built for the wells<br>no one else can save.</h1>
        <p style="font-size:19px;line-height:1.55;color:#c3cee0;max-width:54ch;margin:0 0 34px;">Gunnar is the independent specialist in active magnetic ranging and wellbore intercept — delivering relief wells, blowout kills, complex plug &amp; abandonment, and energy-transition placement. Engineering, ranging, drilling, milling, kill and cement: <strong style="color:#eef1f6;">one accountable team, one call.</strong></p>
        <div style="display:flex;gap:14px;flex-wrap:wrap;margin-bottom:42px;">
          <a href="#contact" style="background:#feee00;color:#0a1626;font-weight:700;font-size:15px;padding:15px 26px;border-radius:3px;">Request a feasibility review</a>
          <a href="#cases" style="border:1px solid rgba(255,255,255,0.28);color:#eef1f6;font-weight:600;font-size:15px;padding:15px 26px;border-radius:3px;">See the case studies →</a>
        </div>
        <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:rgba(255,255,255,0.12);border:1px solid rgba(255,255,255,0.12);">
          {stats.map((s) => (
            <div style="background:#0f2240;padding:16px 14px;">
              <div style="font-family:'Archivo',sans-serif;font-weight:800;font-size:24px;color:#feee00;line-height:1;">{s.n}</div>
              <div style="font-size:11.5px;color:#8493ac;margin-top:6px;line-height:1.3;">{s.l}</div>
            </div>
          ))}
        </div>
      </div>
      <div style="align-self:stretch;min-height:520px;background:#0a1626;border-left:1px solid rgba(255,255,255,0.08);position:relative;overflow:hidden;">
        <img src={url('/assets/hero.png')} alt="Magnetic ranging intercept — drilling well steering to a target wellbore" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;" />
        <div style="position:absolute;inset:0;background:linear-gradient(90deg,rgba(15,34,64,0.55),rgba(10,22,38,0.15));"></div>
      </div>
    </div>
  </section>

  <!-- LOGO TRUST BAR -->
  <section style="background:#0a1626;border-bottom:1px solid rgba(255,255,255,0.07);">
    <div style="max-width:1240px;margin:0 auto;padding:26px 32px;display:flex;align-items:center;gap:40px;flex-wrap:wrap;justify-content:center;">
      <span style="font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:0.14em;color:#5b6a85;">TRUSTED ON THE HIGHEST-STAKES WELLS</span>
      {logos.map((g) => (
        <span style="font-family:'Archivo',sans-serif;font-weight:700;font-size:16px;letter-spacing:0.02em;color:#6c7b96;">{g}</span>
      ))}
    </div>
  </section>

  <!-- ONE CALL DOES IT ALL -->
  <section style="padding:84px 32px;background:#eef1f6;">
    <div style="max-width:1240px;margin:0 auto;">
      <div style="font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:0.2em;color:#1b355e;margin-bottom:14px;">ONE CALL DOES IT ALL</div>
      <h2 style="font-family:'Archivo',sans-serif;font-weight:800;font-size:40px;letter-spacing:-0.02em;margin:0 0 14px;max-width:20ch;">A fully integrated solution for problematic and complex wells.</h2>
      <p style="font-size:18px;color:#5f676e;max-width:64ch;margin:0 0 44px;">From engineering through ranging, intercept, kill and abandonment — delivered end-to-end by one accountable team. No multi-vendor handoffs, no gaps in the chain.</p>
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:24px;">
        {pillars.map((p) => (
          <div style="background:#fff;border:1px solid #d9dfe9;padding:30px;">
            <div style="font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:0.14em;color:#feee00;margin-bottom:8px;">{p.k}</div>
            <h3 style="font-family:'Archivo',sans-serif;font-weight:700;font-size:22px;margin:0 0 16px;color:#0f2240;">{p.t}</h3>
            <ul style="margin:0;padding-left:18px;font-size:14px;line-height:1.7;color:#454c52;">
              {p.items.map((it) => <li>{it}</li>)}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section id="services" style="padding:84px 32px;background:#fff;border-top:1px solid #d9dfe9;border-bottom:1px solid #d9dfe9;">
    <div style="max-width:1240px;margin:0 auto;">
      <div style="display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:16px;margin-bottom:40px;">
        <div>
          <div style="font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:0.2em;color:#1b355e;margin-bottom:14px;">SERVICES</div>
          <h2 style="font-family:'Archivo',sans-serif;font-weight:800;font-size:40px;letter-spacing:-0.02em;margin:0;">What we solve.</h2>
        </div>
        <p style="font-size:15px;color:#5f676e;max-width:42ch;margin:0;">Each service is a dedicated solution — engineered, ranged and executed under one roof.</p>
      </div>
      <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:#d9dfe9;border:1px solid #d9dfe9;">
        {services.map((s) => (
          <a href={url(s.href)} class="hov-bg-soft" style="background:#fff;padding:28px 24px;display:flex;flex-direction:column;min-height:200px;">
            <div style="font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:0.12em;color:#1b355e;margin-bottom:14px;">{s.tag}</div>
            <h3 style="font-family:'Archivo',sans-serif;font-weight:700;font-size:18px;line-height:1.2;margin:0 0 10px;color:#0f2240;">{s.kw}</h3>
            <p style="font-size:13px;color:#5f676e;line-height:1.5;margin:0 0 16px;flex:1;">{s.desc}</p>
            <span style="font-size:13px;font-weight:600;color:#1b355e;">{s.cta} →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- WHAT IS RANGING -->
  <section id="ranging" style="padding:88px 32px;background:#eef1f6;">
    <div style="max-width:1240px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:56px;align-items:center;">
      <div>
        <div style="font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:0.2em;color:#1b355e;margin-bottom:14px;">WHAT IS MAGNETIC RANGING?</div>
        <h2 style="font-family:'Archivo',sans-serif;font-weight:800;font-size:38px;letter-spacing:-0.02em;line-height:1.08;margin:0 0 22px;">Finding one well from another — like GPS for underground wellbores.</h2>
        <p style="font-size:16.5px;line-height:1.65;color:#3a4147;margin:0 0 18px;"><strong>Magnetic ranging is the only proven way to deterministically locate and intercept a target wellbore.</strong> After drilling, a well's exact position is only known approximately — by 10,000 ft, surveys can be off by hundreds of feet. Hitting a target by conventional means is practically impossible.</p>
        <p style="font-size:16.5px;line-height:1.65;color:#3a4147;margin:0 0 28px;">Gunnar injects an electrical current that magnetizes the steel of a nearby target well. By measuring the strength and direction of that magnetic signal, we know exactly where the target is — and steer toward it in real time, <strong>accurate to within an inch at intercept.</strong></p>
        <a href={url('/technology/')} style="font-size:15px;font-weight:600;color:#1b355e;">Explore our five ranging methods →</a>
      </div>
      <div style="background:#0f2240;color:#eef1f6;padding:34px;position:relative;overflow:hidden;">
        <div style="position:absolute;bottom:-90px;right:-70px;width:260px;height:260px;border-radius:50%;border:1px solid rgba(254,238,0,0.18);"></div>
        <div style="position:relative;">
          <div style="font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:0.14em;color:#feee00;margin-bottom:22px;">WHERE RANGING IS ESSENTIAL</div>
          {rangingUses.map((u) => (
            <div style="display:flex;gap:16px;padding:16px 0;border-top:1px solid rgba(255,255,255,0.12);">
              <span style="font-family:'Archivo',sans-serif;font-weight:800;font-size:18px;color:#feee00;flex:none;">{u.n}</span>
              <div>
                <div style="font-weight:600;font-size:15px;color:#eef1f6;margin-bottom:4px;">{u.t}</div>
                <div style="font-size:13.5px;color:#8493ac;line-height:1.5;">{u.b}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- TECHNOLOGY PORTFOLIO -->
  <section id="technology" style="padding:88px 32px;background:#0f2240;color:#eef1f6;">
    <div style="max-width:1240px;margin:0 auto;">
      <div style="font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:0.2em;color:#feee00;margin-bottom:14px;">TECHNOLOGY PORTFOLIO</div>
      <h2 style="font-family:'Archivo',sans-serif;font-weight:800;font-size:40px;letter-spacing:-0.02em;margin:0 0 14px;color:#eef1f6;">Five proprietary ranging methods. One software brain.</h2>
      <p style="font-size:17px;color:#c3cee0;max-width:62ch;margin:0 0 44px;">Chosen for each well's specific geometry, access and risk profile — backed by multiple U.S. patents and an in-house R&amp;D team.</p>

      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:1px;background:rgba(255,255,255,0.12);border:1px solid rgba(255,255,255,0.12);margin-bottom:40px;">
        {methods.map((m) => (
          <div style="background:#0f2240;padding:26px 22px;">
            <div style="font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:0.1em;color:#feee00;margin-bottom:10px;">{m.type}</div>
            <h3 style="font-family:'Archivo',sans-serif;font-weight:700;font-size:20px;margin:0 0 12px;color:#eef1f6;">{m.name}</h3>
            <p style="font-size:13px;color:#8493ac;line-height:1.5;margin:0 0 18px;min-height:60px;">{m.desc}</p>
            <div style="border-top:1px solid rgba(255,255,255,0.1);padding-top:12px;font-size:12px;">
              <div style="display:flex;justify-content:space-between;margin-bottom:6px;"><span style="color:#5b6a85;font-family:'IBM Plex Mono',monospace;letter-spacing:0.06em;">RANGE</span><span style="color:#eef1f6;font-weight:600;">{m.range}</span></div>
              <div style="display:flex;justify-content:space-between;gap:10px;"><span style="color:#5b6a85;font-family:'IBM Plex Mono',monospace;letter-spacing:0.06em;">BEST FOR</span><span style="color:#c3cee0;text-align:right;">{m.best}</span></div>
            </div>
          </div>
        ))}
      </div>

      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:20px;">
        {software.map((sw) => (
          <div style="border:1px solid rgba(254,238,0,0.35);background:rgba(254,238,0,0.05);padding:24px;">
            <div style="font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:0.12em;color:#feee00;margin-bottom:10px;">{sw.tag}</div>
            <h3 style="font-family:'Archivo',sans-serif;font-weight:700;font-size:19px;margin:0 0 10px;color:#eef1f6;">{sw.name}</h3>
            <p style="font-size:13.5px;color:#c3cee0;line-height:1.55;margin:0;">{sw.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PROOF: DEADAHEAD COMPARISON -->
  <section style="padding:88px 32px;background:#fff;border-bottom:1px solid #d9dfe9;">
    <div style="max-width:1240px;margin:0 auto;">
      <div style="display:grid;grid-template-columns:0.9fr 1.1fr;gap:56px;align-items:center;">
        <div>
          <div style="font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:0.18em;color:#1b355e;margin-bottom:14px;">OUR EDGE · DEADAHEAD™ AMR-WHILE-DRILLING</div>
          <h2 style="font-family:'Archivo',sans-serif;font-weight:800;font-size:36px;letter-spacing:-0.02em;line-height:1.1;margin:0 0 20px;">The world's first commercial wired-pipe ranging-while-drilling system.</h2>
          <p style="font-size:16px;line-height:1.65;color:#454c52;margin:0 0 18px;">Continuous ranging from the BHA — no wireline trips. 18× more power delivery than traditional wireline AMR means an earlier locate, a stronger signal and zero re-entry runs for a relief well intercept and kill.</p>
          <p style="font-size:13px;color:#8493ac;line-height:1.55;margin:0;font-style:italic;">U.S. Patent 11,781,421 B2 — reaffirmed by USPTO PTAB (2025). Co-presented at SPE/ISCWSA #62, Alaska, Sept 2025.</p>
        </div>
        <div style="background:#f5f7fb;border:1px solid #d9dfe9;padding:34px;">
          <div style="font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:0.12em;color:#0f2240;font-weight:600;margin-bottom:24px;">DOCUMENTED — EXXONMOBIL, NORTH DAKOTA, 2025</div>
          {deadAhead.map((d) => (
            <div style="display:grid;grid-template-columns:1fr auto 1fr;gap:14px;align-items:center;padding:16px 0;border-top:1px solid #dde3ed;">
              <div><div style="font-family:'Archivo',sans-serif;font-weight:800;font-size:22px;color:#9097a0;">{d.from}</div><div style="font-size:11px;color:#9097a0;">{d.fromL}</div></div>
              <div style="font-family:'IBM Plex Mono',monospace;color:#1b355e;font-size:18px;">→</div>
              <div><div style="font-family:'Archivo',sans-serif;font-weight:800;font-size:22px;color:#0f2240;">{d.to}</div><div style="font-size:11px;color:#5f676e;">{d.toL}</div></div>
            </div>
          ))}
          <div style="margin-top:20px;background:#0f2240;color:#eef1f6;padding:16px 20px;font-size:14px;font-weight:600;">Result: ~2 weeks rig time &amp; ~$2M saved onshore — scaling to tens of millions per well offshore.</div>
        </div>
      </div>
    </div>
  </section>


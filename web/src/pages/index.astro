---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { url } from '../lib/links.js';

const stats = [
  { n: '100%', l: 'intercept success rate' },
  { n: '40+', l: 'projects · 6 countries' },
  { n: '10×', l: 'current vs. wireline ranging' },
  { n: '1 call', l: 'engineering to abandonment' },
];
const logos = ['ExxonMobil', 'Chevron', 'Occidental', 'Woodside', 'Expand Energy', 'SoCalGas', 'Cenovus', 'Devon'];

const pillars = [
  { k: '01', t: 'Engineering', tag: 'Plan it', items: ['Complex P&A & relief well planning', 'Wellbore intercept feasibility studies', 'Ranging signal modeling & survey integration', 'Regulatory & risk documentation'] },
  { k: '02', t: 'Technology', tag: 'Build it', items: ['DeadAhead™ wired-pipe AMR-While-Drilling', 'DeadSet™ wireline active ranging', 'CTRWD™ coiled-tubing ranging', 'TopGun™ AI interpretation software'] },
  { k: '03', t: 'Field Operations', tag: 'Execute it', items: ['Relief well drilling & blowout intercept', 'Well kill & well control', 'Outside-in milling & re-entry', 'Regulator-witnessed permanent P&A'] },
];

const services = [
  { tag: 'Well Control', kw: 'Relief Well & Blowout Intercept', desc: 'Deterministic intercept and kill when surface control has failed.', cta: 'Emergency response', href: '/services/relief-wells/' },
  { tag: 'P&A', kw: 'Plug & Abandonment', desc: 'No-access ranging that seals complex and legacy wells — cutting rig time up to 50%.', cta: 'Reduce P&A cost', href: '/services/plug-and-abandonment/' },
  { tag: 'Ranging', kw: 'Active Magnetic Ranging', desc: 'The only proven way to deterministically locate and intercept a target wellbore.', cta: 'See methods', href: '/technology/' },
  { tag: 'Intervention', kw: 'Well Re-Entry & Milling', desc: 'Outside-in milling and re-entry of damaged casing, stuck packers and lost-access wells.', cta: 'Learn more', href: '/services/well-re-entry/' },
  { tag: 'Energy Transition', kw: 'Geothermal Well Placement', desc: 'Precise intersection and closed-loop connection for next-generation geothermal.', cta: 'Explore', href: '/services/geothermal/' },
  { tag: 'Energy Transition', kw: 'CCUS Well Integrity', desc: 'Wellbore placement and integrity assurance for carbon capture and storage.', cta: 'Explore', href: '/services/ccus/' },
  { tag: 'Mining', kw: 'Solution Mining Connections', desc: 'Wellbore intercept for potash, lithium and uranium recovery.', cta: 'Learn more', href: '/services/solution-mining/' },
  { tag: 'Unconventional', kw: 'SAGD & CSG Twinning', desc: 'Precise well twinning, spacing and intercept for enhanced unconventional production.', cta: 'Learn more', href: '/services/' },
];

const rangingUses = [
  { n: '1', t: 'Relief wells & blowouts', b: 'When surface kill has failed, we drill an intercept well that finds and connects with the wild well — then kill it from below.' },
  { n: '2', t: 'Plug & abandonment', b: 'When old wells have damaged casing, stuck packers or lost surface access, we drill a new path that intercepts them for a permanent seal.' },
  { n: '3', t: 'Twinning, avoidance & intercept', b: 'On multi-pad developments we hold precise spacing to prevent frac hits and collisions — and intercept targets for enhanced production.' },
];

const methods = [
  { type: 'Active · While Drilling', name: 'DeadAhead™', desc: 'Wired drillpipe for continuous ranging while drilling — ~10× the current of wireline. World-first commercial deployment.', range: 'up to 500 ft', best: 'Relief wells, blowout intercepts' },
  { type: 'Active · Wireline', name: 'DeadSet™', desc: 'MEMS/solid-state wireline AMR with interchangeable sensors and optional gyro.', range: '200 ft', best: 'Relief wells, P&A' },
  { type: 'While Drilling · Coiled Tubing', name: 'CT-RWD™', desc: 'Active ranging inside a pressure-contained coiled-tubing BHA — ranges a live well.', range: 'up to 200 ft', best: 'Live-well / under-pressure intercept' },
  { type: 'Magnetic Source', name: 'Torped™', desc: 'At-bit magnetic source detected by a receiver in the offset well — vendor-neutral.', range: '275 ft', best: 'Twinning, intersection, avoidance' },
  { type: 'Passive', name: 'EverReady™', desc: 'No-access ranging from existing MWD/steering data — processed remotely, no new tools.', range: '>30 ft', best: 'No-access ranging' },
];
const software = [
  { tag: 'AI · Ranging & Interpretation', name: 'TopGun™', desc: 'Web-based suite for automated ranging analysis, 3D visualization and real-time decision support, with a GPT-driven interpretation layer.' },
  { tag: 'Intercept & Milling', name: 'ClearCut™', desc: 'Precision milling simulation that turns intercept geometry into real-world milling parameters — reducing rig time and operational risk.' },
  { tag: 'AI-Driven Passive Ranging', name: 'EverReady™ Software', desc: 'Non-intrusive ranging from existing MWD/GWD data — fully remote, AI-driven interpretation with proprietary interference processing.' },
];

const deadAhead = [
  { from: '~46 days', fromL: 'Wireline AMR', to: '~32 days', toL: 'AMR-While-Drilling' },
  { from: '20+ runs', fromL: 'Wireline AMR', to: '4 runs', toL: 'AMR-While-Drilling' },
  { from: '~8 A', fromL: 'injection power', to: '~10× stronger', toL: 'earlier locate, more margin' },
];

const cases = [
  { href: '/case-studies/exxonmobil-north-dakota/', img: '/assets/case-exxonmobil.jpg', scope: 'Intercept · Kill · P&A', client: 'ExxonMobil', loc: 'North Dakota · 2025', body: 'Tubing parted at ~1,000 ft with only a 10 ft window below a stuck packer. DeadAhead™ held 5–10 ft separation over 5,500 ft of continuous ranging — the world\'s first commercial wired-pipe AMR-WD deployment.', metric: '8,642 ft MD', metricL: 'intercepted at exact planned depth · ~$2M saved' },
  { href: '/case-studies/expand-energy-louisiana/', img: '/assets/case-expand-energy.jpg', scope: 'Blowout · Well Kill · P&A', client: 'Expand Energy', loc: 'Louisiana · 2025', body: 'An unpermitted 1950s-era legacy well leaked 5,000 bbl/day for 116 days of failed surface intervention. CT-RWD™ coiled-tubing ranging located and intercepted the unknown geometry at 1,068 ft MD.', metric: '15 days', metricL: 'to well control vs. 116 days of surface attempts' },
  { href: '/case-studies/socalgas-aliso-canyon/', img: '/assets/case-socalgas.jpg', scope: 'Relief Well P&A · Dual Intercept', client: 'SoCalGas — Aliso Canyon', loc: 'California · 2020–ongoing', body: 'Relief-well P&A of 1950s-era wells at the site of the largest gas blowout in U.S. history. DeadSet™ AMR and EverReady™ PMR overcame missing surveys and a parasite sidetrack.', metric: '8 intercepts', metricL: 'across a 4-well campaign · regulator-approved' },
];

const diffs = [
  { t: 'Proprietary technology', b: 'DeadAhead™ wired-pipe AMR-WD delivers ~10× the current injection of wireline ranging — backed by a multi-patent estate and in-house R&D.' },
  { t: 'Proven track record', b: '100% intercept success across 40+ projects, including world-record dual 29,500 ft intercepts. Documented and regulator-witnessed.' },
  { t: 'One integrated call', b: 'Engineering, ranging, directional, milling, kill, cement and abandonment by one accountable team — one contract, one timeline.' },
  { t: 'High barriers to entry', b: 'A proprietary fleet of ranging hardware supercharged by AI — and 140+ combined years of expertise on the highest-stakes wells.' },
];

const faqs = [
  { q: 'What is magnetic ranging?', a: 'Magnetic ranging is a technique that determines the distance and direction from a drilling well to a nearby target wellbore by measuring a magnetic field on the target\'s steel casing. It is the only proven method to deterministically locate and intercept a target well when conventional surveys are too uncertain.' },
  { q: 'What is a relief well?', a: 'A relief well is a separate well drilled to intentionally intersect a blowing or uncontrolled well so it can be killed from below. Modern relief wells use active magnetic ranging to steer to the target with inch-level accuracy at the point of intercept.' },
  { q: 'When do you need active vs. passive ranging?', a: 'Passive ranging (EverReady™) uses the target casing\'s existing magnetism and works at short range with no extra tools. Active ranging (DeadSet™, DeadAhead™) injects a current to generate a strong, controllable signal — essential for longer ranges, relief wells and blowout intercepts.' },
  { q: 'How does ranging reduce plug & abandonment cost?', a: 'No-access ranging-while-drilling eliminates time-consuming wireline round-trips and open-hole exposure. On complex P&A this can save roughly half the rig time and millions of dollars versus conventional wireline methods.' },
  { q: 'Can magnetic ranging be used for CCUS and geothermal?', a: 'Yes. Carbon storage requires verified well integrity and precise placement, and closed-loop geothermal relies on intentionally intersecting two wellbores — both are core ranging applications Gunnar delivers.' },
  { q: 'How accurate is a wellbore intercept?', a: 'With active ranging, accuracy improves as the drilling well homes in on the target — reaching inch-level precision at intercept, even at depths where conventional surveys are off by hundreds of feet.' },
];

const vid = 'iLe8lQrgoWg';
const vidEmbed = `https://www.youtube-nocookie.com/embed/${vid}?autoplay=1&rel=0&modestbranding=1`;
const vidThumb = `https://i.ytimg.com/vi/${vid}/hqdefault.jpg`;
---
<Layout title="Gunnar Energy Services — Relief Wells, Magnetic Ranging & Wellbore Intercept" description="Built for the wells no one else can save. Gunnar is the independent specialist in active magnetic ranging, relief wells, blowout kills, plug & abandonment, CCUS and geothermal placement.">
  <SiteHeader />

  <!-- HERO -->
  <section class="dotgrid" style="position:relative;background:var(--ground-2);overflow:hidden;min-height:90vh;display:flex;align-items:flex-end;">
    <div class="cine" style="position:absolute;inset:0;">
      <img src={url('/assets/hero.jpg')} alt="Gunnar wired-pipe land drilling rig at blue hour" />
    </div>
    <div class="wrap" style="position:relative;padding-top:clamp(80px,16vh,180px);padding-bottom:56px;">
      <div data-reveal>
        <div class="kicker-row" style="margin-bottom:28px;"><span class="eyebrow">Relief Wells · Magnetic Ranging · Wellbore Intercept</span></div>
        <h1 class="display d-xl" style="max-width:16ch;">Built for the wells no one else can save.</h1>
        <p class="lede" style="max-width:58ch;margin:28px 0 36px;color:var(--text);">
          The independent specialist in active magnetic ranging and wellbore intercept — relief wells, blowout kills, complex plug &amp; abandonment, and energy-transition placement. Engineering, ranging, drilling, milling, kill and cement: <strong style="color:#fff;font-weight:600;">one accountable team, one call.</strong>
        </p>
        <div style="display:flex;gap:14px;flex-wrap:wrap;">
          <a href={url('/contact/')} class="btn btn-primary">Request a feasibility review</a>
          <a href="#cases" class="btn btn-ghost">See the case studies →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- STAT STRIP -->
  <section style="background:var(--ground-2);border-top:1px solid var(--line);border-bottom:1px solid var(--line);">
    <div class="wrap" style="display:grid;grid-template-columns:repeat(4,1fr);">
      {stats.map((s, i) => (
        <div style={`padding:26px 8px;${i ? 'border-left:1px solid var(--line);' : ''}padding-left:${i ? '28px' : '0'};`}>
          <div class="display" style="font-size:clamp(28px,3.4vw,44px);color:var(--accent);line-height:1;">{s.n}</div>
          <div class="faint" style="font-family:var(--mono);font-size:11px;letter-spacing:0.08em;text-transform:uppercase;margin-top:10px;">{s.l}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- TRUST BAR -->
  <section style="background:var(--ground);border-bottom:1px solid var(--line);">
    <div class="wrap" style="display:flex;align-items:center;gap:36px;flex-wrap:wrap;justify-content:center;padding-top:24px;padding-bottom:24px;">
      <span class="eyebrow eyebrow--dim">Trusted on the highest-stakes wells</span>
      {logos.map((g) => (
        <span style="font-family:var(--display-n);font-weight:700;font-size:15px;letter-spacing:0.02em;color:var(--text-faint);">{g}</span>
      ))}
    </div>
  </section>

  <!-- ONE CALL DOES IT ALL -->
  <section class="section" style="background:var(--ground);">
    <div class="wrap">
      <div data-reveal style="max-width:60ch;margin-bottom:56px;">
        <div class="kicker-row" style="margin-bottom:22px;"><span class="eyebrow">One call does it all</span></div>
        <h2 class="display d-l">A fully integrated solution for problematic and complex wells.</h2>
        <p class="lede" style="margin-top:20px;">From engineering through ranging, intercept, kill and abandonment — delivered end-to-end by one accountable team. No multi-vendor handoffs, no gaps in the chain.</p>
      </div>
      <div class="hgrid cols-3" style="grid-template-columns:repeat(3,1fr);" data-reveal>
        {pillars.map((p) => (
          <div style="padding:34px 30px;">
            <div style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:20px;">
              <span class="eyebrow">{p.tag}</span>
              <span class="display" style="font-size:24px;color:var(--line-strong);">{p.k}</span>
            </div>
            <h3 class="h-card" style="font-size:23px;margin-bottom:18px;">{p.t}</h3>
            <ul style="margin:0;padding:0;list-style:none;">
              {p.items.map((it) => (
                <li style="font-size:14px;line-height:1.5;color:var(--text-dim);padding:9px 0;border-top:1px solid var(--line-2);display:flex;gap:10px;"><span style="color:var(--accent);">—</span>{it}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="section" style="background:var(--ground-2);border-top:1px solid var(--line);" id="services">
    <div class="wrap">
      <div data-reveal style="display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:20px;margin-bottom:48px;">
        <div>
          <div class="kicker-row" style="margin-bottom:22px;"><span class="eyebrow">Services</span></div>
          <h2 class="display d-l">What we solve.</h2>
        </div>
        <p class="muted" style="max-width:42ch;font-size:15px;">Each service is a dedicated solution — engineered, ranged and executed under one roof.</p>
      </div>
      <div class="hgrid cols-4" style="grid-template-columns:repeat(4,1fr);" data-reveal>
        {services.map((s) => (
          <a href={url(s.href)} class="tile tile--link" style="padding:30px 26px;display:flex;flex-direction:column;min-height:230px;background:var(--ground);">
            <div class="eyebrow eyebrow--dim" style="margin-bottom:18px;">{s.tag}</div>
            <h3 class="h-card" style="font-size:18px;margin-bottom:12px;color:var(--text);">{s.kw}</h3>
            <p style="font-size:13px;color:var(--text-dim);line-height:1.5;margin:0 0 18px;flex:1;">{s.desc}</p>
            <span style="font-family:var(--mono);font-size:11px;letter-spacing:0.1em;text-transform:uppercase;color:var(--accent);">{s.cta} →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- WHAT IS RANGING -->
  <section class="section" style="background:var(--ground);" id="ranging">
    <div class="wrap" style="display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center;">
      <div data-reveal>
        <div class="kicker-row" style="margin-bottom:22px;"><span class="eyebrow">What is magnetic ranging?</span></div>
        <h2 class="display d-m" style="margin-bottom:24px;">Finding one well from another — like GPS for underground wellbores.</h2>
        <p style="font-size:16px;line-height:1.7;color:var(--text-dim);margin:0 0 18px;"><strong style="color:var(--text);">Magnetic ranging is the only proven way to deterministically locate and intercept a target wellbore.</strong> After drilling, a well's exact position is only known approximately — by 10,000 ft, surveys can be off by hundreds of feet. Hitting a target by conventional means is practically impossible.</p>
        <p style="font-size:16px;line-height:1.7;color:var(--text-dim);margin:0 0 28px;">Gunnar injects an electrical current that magnetizes the steel of a nearby target well. By measuring the strength and direction of that signal, we know exactly where the target is — and steer toward it in real time, <strong style="color:var(--text);">accurate to within an inch at intercept.</strong></p>
        <a href={url('/technology/')} style="font-family:var(--mono);font-size:12px;letter-spacing:0.1em;text-transform:uppercase;color:var(--accent);">Explore our five ranging methods →</a>
      </div>
      <div class="tile" data-reveal style="padding:36px;background:var(--surface);">
        <div class="eyebrow" style="margin-bottom:24px;">Where ranging is essential</div>
        {rangingUses.map((u) => (
          <div style="display:flex;gap:18px;padding:18px 0;border-top:1px solid var(--line);">
            <span class="display" style="font-size:20px;color:var(--accent);flex:none;">{u.n}</span>
            <div>
              <div style="font-weight:600;font-size:15px;color:var(--text);margin-bottom:5px;">{u.t}</div>
              <div style="font-size:13.5px;color:var(--text-dim);line-height:1.55;">{u.b}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TECHNOLOGY PORTFOLIO -->
  <section class="section" style="background:var(--ground-2);border-top:1px solid var(--line);" id="technology">
    <div class="wrap">
      <div data-reveal style="max-width:62ch;margin-bottom:48px;">
        <div class="kicker-row" style="margin-bottom:22px;"><span class="eyebrow">Technology portfolio</span></div>
        <h2 class="display d-l">Five proprietary ranging methods. One software brain.</h2>
        <p class="lede" style="margin-top:20px;">Chosen for each well's specific geometry, access and risk profile — backed by multiple U.S. patents and an in-house R&amp;D team.</p>
      </div>
      <div class="hgrid" style="grid-template-columns:repeat(auto-fit,minmax(230px,1fr));margin-bottom:24px;" data-reveal>
        {methods.map((m) => (
          <div style="padding:28px 24px;background:var(--ground);">
            <div class="eyebrow eyebrow--dim" style="margin-bottom:12px;">{m.type}</div>
            <h3 class="h-card" style="font-size:21px;color:var(--accent);margin-bottom:12px;">{m.name}</h3>
            <p style="font-size:13px;color:var(--text-dim);line-height:1.55;margin:0 0 20px;min-height:58px;">{m.desc}</p>
            <div style="border-top:1px solid var(--line);padding-top:14px;font-size:12px;">
              <div style="display:flex;justify-content:space-between;margin-bottom:7px;"><span class="faint" style="font-family:var(--mono);letter-spacing:0.06em;">RANGE</span><span style="color:var(--text);font-weight:600;">{m.range}</span></div>
              <div style="display:flex;justify-content:space-between;gap:10px;"><span class="faint" style="font-family:var(--mono);letter-spacing:0.06em;">BEST FOR</span><span style="color:var(--text-dim);text-align:right;">{m.best}</span></div>
            </div>
          </div>
        ))}
      </div>
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:18px;" class="cols-3" data-reveal>
        {software.map((sw) => (
          <div style="border:1px solid rgba(254,238,0,0.32);background:rgba(254,238,0,0.04);padding:26px;">
            <div class="eyebrow" style="margin-bottom:12px;">{sw.tag}</div>
            <h3 class="h-card" style="font-size:19px;margin-bottom:10px;color:var(--text);">{sw.name}</h3>
            <p style="font-size:13.5px;color:var(--text-dim);line-height:1.55;margin:0;">{sw.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- DEADAHEAD PROOF -->
  <section class="section" style="background:var(--ground);">
    <div class="wrap" style="display:grid;grid-template-columns:0.95fr 1.05fr;gap:64px;align-items:center;">
      <div data-reveal>
        <div class="kicker-row" style="margin-bottom:22px;"><span class="eyebrow">Our edge · DeadAhead™ AMR-WD</span></div>
        <h2 class="display d-m" style="margin-bottom:22px;">The world's first commercial wired-pipe ranging-while-drilling system.</h2>
        <p style="font-size:16px;line-height:1.7;color:var(--text-dim);margin:0 0 20px;">Continuous ranging from the BHA — no wireline trips. ~10× more current injection than traditional wireline AMR means an earlier locate, a stronger signal and zero re-entry runs for a relief well intercept and kill.</p>
        <p class="faint" style="font-size:12.5px;line-height:1.6;font-style:italic;margin:0;">U.S. Patent 11,781,421 B2 — reaffirmed by USPTO PTAB (2025). Co-presented at SPE/ISCWSA #62, Alaska, Sept 2025.</p>
      </div>
      <div class="tile" data-reveal style="padding:36px;background:var(--surface);">
        <div class="eyebrow eyebrow--dim" style="margin-bottom:24px;">Documented — ExxonMobil, North Dakota, 2025</div>
        {deadAhead.map((d) => (
          <div style="display:grid;grid-template-columns:1fr auto 1fr;gap:16px;align-items:center;padding:16px 0;border-top:1px solid var(--line);">
            <div><div class="display" style="font-size:22px;color:var(--text-faint);">{d.from}</div><div class="faint" style="font-size:11px;">{d.fromL}</div></div>
            <div style="font-family:var(--mono);color:var(--accent);font-size:16px;">→</div>
            <div><div class="display" style="font-size:22px;color:var(--text);">{d.to}</div><div style="font-size:11px;color:var(--text-dim);">{d.toL}</div></div>
          </div>
        ))}
        <div style="margin-top:22px;background:var(--accent);color:#0A0C0F;padding:16px 20px;font-size:14px;font-weight:600;">Result: ~2 weeks rig time &amp; ~$2M saved onshore — scaling to tens of millions per well offshore.</div>
      </div>
    </div>
  </section>

  <!-- VIDEO BAND -->
  <section style="background:var(--ground-2);border-top:1px solid var(--line);padding-top:var(--section-y);padding-bottom:var(--section-y);" id="video">
    <div class="wrap">
      <div data-reveal style="display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:20px;margin-bottom:34px;">
        <div>
          <div class="kicker-row" style="margin-bottom:22px;"><span class="eyebrow">See it in action</span></div>
          <h2 class="display d-l">The technology, explained by the people who built it.</h2>
        </div>
        <a href={url('/videos/')} style="font-family:var(--mono);font-size:12px;letter-spacing:0.1em;text-transform:uppercase;color:var(--accent);">Browse the video library →</a>
      </div>
      <div data-video-frame data-reveal style="position:relative;width:100%;aspect-ratio:16/9;max-height:600px;background:var(--ground);overflow:hidden;border:1px solid var(--line);">
        <div data-video-facade data-embed={vidEmbed} data-title="A Breakthrough in Directional Drilling & Magnetic Ranging" style={`position:absolute;inset:0;cursor:pointer;background-image:url('${vidThumb}');background-size:cover;background-position:center;filter:grayscale(0.2);`}>
          <div style="position:absolute;inset:0;background:linear-gradient(180deg,rgba(10,12,15,0.2),rgba(10,12,15,0.72));"></div>
          <div style="position:absolute;left:clamp(20px,4vw,52px);bottom:40px;max-width:60%;">
            <div class="eyebrow" style="margin-bottom:12px;">Case study</div>
            <div class="display d-m" style="color:#fff;">A Breakthrough in Directional Drilling &amp; Magnetic Ranging</div>
          </div>
          <div style="position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);width:92px;height:92px;border-radius:50%;background:var(--accent);display:flex;align-items:center;justify-content:center;">
            <div style="width:0;height:0;border-left:28px solid #0A0C0F;border-top:17px solid transparent;border-bottom:17px solid transparent;margin-left:7px;"></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CASE STUDIES -->
  <section class="section" style="background:var(--ground);" id="cases">
    <div class="wrap">
      <div data-reveal style="margin-bottom:48px;">
        <div class="kicker-row" style="margin-bottom:22px;"><span class="eyebrow">Case studies</span></div>
        <h2 class="display d-l">Proof, not promises.</h2>
      </div>
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:24px;" class="cols-3" data-reveal>
        {cases.map((c) => (
          <a href={url(c.href)} class="tile tile--link" style="display:flex;flex-direction:column;">
            <div class="cine" style="height:170px;display:flex;align-items:flex-end;padding:16px;border-bottom:1px solid var(--line);">
              <img src={url(c.img)} alt={c.client} />
              <span class="eyebrow" style="position:relative;font-size:10px;">{c.scope}</span>
            </div>
            <div style="padding:26px;flex:1;display:flex;flex-direction:column;">
              <h3 class="h-card" style="font-size:19px;margin-bottom:4px;color:var(--text);">{c.client}</h3>
              <div class="faint" style="font-size:12px;margin-bottom:16px;">{c.loc}</div>
              <p style="font-size:13.5px;color:var(--text-dim);line-height:1.55;margin:0 0 18px;flex:1;">{c.body}</p>
              <div style="border-top:1px solid var(--line);padding-top:16px;">
                <div class="display" style="font-size:26px;color:var(--accent);">{c.metric}</div>
                <div style="font-size:12.5px;color:var(--text-dim);margin-top:5px;">{c.metricL}</div>
              </div>
            </div>
          </a>
        ))}
      </div>
      <div style="margin-top:36px;"><a href={url('/case-studies/')} style="font-family:var(--mono);font-size:12px;letter-spacing:0.1em;text-transform:uppercase;color:var(--accent);">See all case studies →</a></div>
    </div>
  </section>

  <!-- WHY GUNNAR -->
  <section class="section" style="background:var(--ground-2);border-top:1px solid var(--line);">
    <div class="wrap">
      <div data-reveal style="margin-bottom:48px;">
        <div class="kicker-row" style="margin-bottom:22px;"><span class="eyebrow">Why Gunnar</span></div>
        <h2 class="display d-l" style="max-width:22ch;">A defensible moat across technology, execution and integration.</h2>
      </div>
      <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:28px;" class="cols-4" data-reveal>
        {diffs.map((d) => (
          <div style="border-top:1px solid var(--accent);padding-top:20px;">
            <h3 class="h-card" style="font-size:18px;margin-bottom:12px;color:var(--text);">{d.t}</h3>
            <p style="font-size:13.5px;color:var(--text-dim);line-height:1.6;margin:0;">{d.b}</p>
          </div>
        ))}
      </div>
      <div style="margin-top:44px;display:flex;gap:32px;flex-wrap:wrap;align-items:center;border:1px solid var(--line);background:var(--ground);padding:22px 28px;">
        <span class="eyebrow eyebrow--dim">Certified &amp; compliant</span>
        {['ISO 9001', 'API Q1 / Q2', 'ISNetworld', 'Regulator-Witnessed'].map((b) => (
          <span style="font-family:var(--display-n);font-weight:700;font-size:15px;color:var(--text-dim);">{b}</span>
        ))}
        <span class="faint" style="font-size:11.5px;font-style:italic;">— confirm/replace badges with current certifications</span>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" style="background:var(--ground);">
    <div class="wrap" style="max-width:960px;">
      <div data-reveal style="margin-bottom:40px;">
        <div class="kicker-row" style="margin-bottom:22px;"><span class="eyebrow">Frequently asked</span></div>
        <h2 class="display d-l">Answers built for engineers.</h2>
      </div>
      <div data-reveal>
        {faqs.map((f) => (
          <div style="border-top:1px solid var(--line);padding:26px 0;">
            <h3 class="h-card" style="font-size:19px;margin-bottom:10px;color:var(--text);">{f.q}</h3>
            <p style="font-size:15px;line-height:1.7;color:var(--text-dim);margin:0;">{f.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section class="section dotgrid" style="background:var(--ground-2);border-top:1px solid var(--line);position:relative;overflow:hidden;" id="contact">
    <div class="wrap" style="position:relative;display:grid;grid-template-columns:1.15fr 1fr;gap:64px;align-items:center;">
      <div data-reveal>
        <div class="kicker-row" style="margin-bottom:22px;"><span class="eyebrow">Let's talk</span></div>
        <h2 class="display d-l">Have a well that has to be hit?</h2>
        <p class="lede" style="margin:22px 0 32px;max-width:48ch;">Tell us about the well — geometry, access and timeline — and a ranging engineer will scope a deterministic intercept plan. For active well-control emergencies, call the 24/7 line now.</p>
        <div style="display:flex;gap:14px;flex-wrap:wrap;">
          <a href="tel:+18325550100" class="btn btn-primary">24/7 Emergency: +1 832 555 0100</a>
          <a href="mailto:info@gunnarenergyservices.com" class="btn btn-ghost">Email an engineer</a>
        </div>
      </div>
      <div class="tile" data-reveal style="padding:32px;background:var(--surface);">
        <div class="eyebrow" style="margin-bottom:20px;">Request a feasibility review</div>
        <form data-feasibility style="display:grid;gap:12px;">
          <input class="gx-field" type="text" name="name" placeholder="Name" required />
          <input class="gx-field" type="text" name="company_email" placeholder="Company & email" required />
          <input class="gx-field" type="text" name="application" placeholder="Application — relief well / P&A / CCUS / geothermal" />
          <textarea class="gx-field" name="details" placeholder="Well details & timeline" style="height:84px;"></textarea>
          <button class="gx-submit" type="submit">Submit request</button>
          <p data-form-status class="faint" style="font-size:12px;margin:2px 0 0;line-height:1.5;"></p>
        </form>
      </div>
    </div>
  </section>

  <SiteFooter />
</Layout>

<script>
  import '../scripts/video-facade.js';
  import '../scripts/forms.js';
</script>

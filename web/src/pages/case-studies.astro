---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { url } from '../lib/links.js';

const featured = [
  { img: 'INTERCEPT OPERATIONS', scope: 'INTERCEPT · KILL · P&A', sector: 'OIL & GAS · WELL CONTROL', title: 'ExxonMobil — North Dakota', loc: '2025 · World-first commercial wired-pipe AMR-while-drilling',
    body: 'Tubing parted at ~1,000 ft with only a 10 ft window below a stuck packer. Gunnar\'s DeadAhead™ wired-pipe system held 5–10 ft separation across 5,500 ft of continuous ranging and intercepted at the exact planned depth — the first commercial deployment of wired-pipe AMR-while-drilling in the world.',
    metrics: [{ n: '8,642 ft', l: 'intercept at exact planned MD' }, { n: '~2 weeks', l: 'rig time saved' }, { n: '~$2M', l: 'cost saved onshore' }] },
  { img: 'BLOWOUT INTERVENTION', scope: 'BLOWOUT · WELL KILL · P&A', sector: 'OIL & GAS · EMERGENCY RESPONSE', title: 'Expand Energy — Louisiana', loc: '2025 · Legacy blowout intercept',
    body: 'An unpermitted 1950s-era legacy well leaked ~5,000 bbl/day through 116 days of failed surface intervention. Gunnar\'s CTRWD™ coiled-tubing ranging located and intercepted the unknown wellbore geometry, bringing the well under control where surface methods could not.',
    metrics: [{ n: '15 days', l: 'to well control' }, { n: '1,068 ft', l: 'intercept of unknown geometry' }, { n: '116→0', l: 'days of leakage ended' }] },
  { img: 'RELIEF WELL P&A', scope: 'RELIEF WELL P&A · DUAL INTERCEPT', sector: 'OIL & GAS · LEGACY REMEDIATION', title: 'SoCalGas — Aliso Canyon', loc: 'California · 2020–ongoing',
    body: 'Relief-well P&A of 1950s-era wells at the site of the largest gas blowout in U.S. history. Gunnar overcame missing surveys and a parasite sidetrack using DeadSet™ active ranging and EverReady™ passive ranging across a multi-well campaign.',
    metrics: [{ n: '8 intercepts', l: 'across a 4-well campaign' }, { n: 'Regulator', l: 'witnessed & approved' }, { n: 'Missing surveys', l: 'overcome with ranging' }] },
];
const more = [
  { scope: 'URBAN P&A · LAND REUSE', title: 'Boyle Heights Urban Abandonment', loc: 'Los Angeles · 2021 · with Di Drill', body: 'Permanently plugged an old urban oil well posing health and environmental hazards, securing CalGEM certification and unlocking land now slated for affordable housing.' },
  { scope: 'WORLD RECORD · DEEP INTERCEPT', title: 'World\'s Deepest Intercept', loc: 'Dual 29,500 ft intercept', body: 'Gunnar executed the deepest wellbore intercept ever performed — a record-setting demonstration of ranging accuracy at extreme depth.' },
  { scope: 'CCUS · ZONAL ISOLATION', title: 'Carbon Storage Well Integrity', loc: 'Presented at DEA(e), Stavanger', body: 'Demonstrated how ranging and intercept technology seals depleted reservoirs and enables efficient CO₂ injection and sequestration in storage complexes.' },
];
---
<Layout title="Case Studies — Documented Intercepts & Well-Control Projects | Gunnar Energy Services" description="A 100% intercept success record on the hardest wells in the world — ExxonMobil North Dakota, Expand Energy Louisiana, SoCalGas Aliso Canyon and more.">
  <SiteHeader />

  <section style="background:#0f2240;color:#eef1f6;position:relative;overflow:hidden;padding:64px 32px 70px;">
    <div style="position:absolute;inset:0;background-image:radial-gradient(rgba(255,255,255,0.045) 1px,transparent 1px);background-size:28px 28px;opacity:0.6;"></div>
    <div style="position:absolute;top:-180px;right:-140px;width:520px;height:520px;border-radius:50%;border:1px solid rgba(254,238,0,0.14);"></div>
    <div style="max-width:1240px;margin:0 auto;position:relative;">
      <div style="font-family:'IBM Plex Mono',monospace;font-size:11.5px;letter-spacing:0.08em;color:#8493ac;margin-bottom:24px;"><a href={url('/')} style="color:#8493ac;">Home</a> &nbsp;/&nbsp; <span style="color:#feee00;">Case Studies</span></div>
      <div style="font-family:'IBM Plex Mono',monospace;font-size:12.5px;letter-spacing:0.18em;color:#feee00;margin-bottom:18px;">PROOF, NOT PROMISES</div>
      <h1 style="font-family:'Archivo',sans-serif;font-weight:900;font-size:54px;line-height:1.02;letter-spacing:-0.025em;margin:0 0 22px;max-width:18ch;">The wells the industry said couldn't be done.</h1>
      <p style="font-size:19px;line-height:1.55;color:#c3cee0;max-width:62ch;margin:0;">A 100% intercept success rate isn't a slogan — it's a record built on the hardest wells in the world, documented and regulator-witnessed. A selection of representative projects follows.</p>
    </div>
  </section>

  <section style="padding:72px 32px;background:#eef1f6;">
    <div style="max-width:1240px;margin:0 auto;">
      {featured.map((c) => (
        <div style="background:#fff;border:1px solid #d9dfe9;margin-bottom:28px;display:grid;grid-template-columns:1fr 1.25fr;gap:0;">
          <div style="background:#102444;background-image:repeating-linear-gradient(135deg,rgba(255,255,255,0.05) 0 11px,transparent 11px 22px);min-height:300px;position:relative;display:flex;align-items:flex-end;padding:22px;">
            <span style="position:absolute;top:20px;left:22px;font-family:'IBM Plex Mono',monospace;font-size:10px;color:#5b6a85;">[ {c.img} ]</span>
            <span style="font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:0.1em;color:#feee00;">{c.scope}</span>
          </div>
          <div style="padding:36px;display:flex;flex-direction:column;">
            <div style="font-family:'IBM Plex Mono',monospace;font-size:11px;letter-spacing:0.14em;color:#1b355e;margin-bottom:12px;">{c.sector}</div>
            <h2 style="font-family:'Archivo',sans-serif;font-weight:800;font-size:28px;letter-spacing:-0.02em;margin:0 0 4px;color:#0f2240;">{c.title}</h2>
            <div style="font-size:13.5px;color:#8493ac;margin-bottom:18px;">{c.loc}</div>
            <p style="font-size:15px;line-height:1.65;color:#454c52;margin:0 0 22px;flex:1;">{c.body}</p>
            <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:#d9dfe9;border:1px solid #d9dfe9;">
              {c.metrics.map((m) => (
                <div style="background:#f5f7fb;padding:16px 18px;"><div style="font-family:'Archivo',sans-serif;font-weight:800;font-size:20px;color:#1b355e;line-height:1;">{m.n}</div><div style="font-size:11.5px;color:#5f676e;margin-top:5px;line-height:1.35;">{m.l}</div></div>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section style="padding:24px 32px 80px;background:#eef1f6;">
    <div style="max-width:1240px;margin:0 auto;">
      <div style="font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:0.2em;color:#1b355e;margin-bottom:22px;">MORE PROJECTS</div>
      <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:24px;">
        {more.map((c) => (
          <div style="background:#fff;border:1px solid #d9dfe9;padding:26px;">
            <div style="font-family:'IBM Plex Mono',monospace;font-size:10px;letter-spacing:0.12em;color:#1b355e;margin-bottom:12px;">{c.scope}</div>
            <h3 style="font-family:'Archivo',sans-serif;font-weight:700;font-size:19px;margin:0 0 4px;color:#0f2240;line-height:1.2;">{c.title}</h3>
            <div style="font-size:12.5px;color:#8493ac;margin-bottom:14px;">{c.loc}</div>
            <p style="font-size:13.5px;color:#5f676e;line-height:1.55;margin:0;">{c.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <SiteFooter />
</Layout>

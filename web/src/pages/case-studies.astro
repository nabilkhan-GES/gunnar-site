---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { url } from '../lib/links.js';
import { caseStudies } from '../data/case-studies.js';

const featured = caseStudies.filter((c) => c.featured);
const all = caseStudies;
const stats = [
  { n: '40+', l: 'projects delivered' },
  { n: '100%', l: 'intercept success rate' },
  { n: '13+', l: 'relief well / blowout jobs' },
  { n: '6', l: 'countries' },
];
---
<Layout title="Case Studies — Documented Intercepts & Well-Control Projects | Gunnar Energy Services" description="A 100% intercept record across 40+ projects in 6 countries — relief wells, blowout intercepts, complex P&A, geothermal and solution mining. Documented and regulator-witnessed.">
  <SiteHeader />

  <!-- HERO -->
  <section class="dotgrid" style="background:var(--ground-2);border-bottom:1px solid var(--line);">
    <div class="wrap" style="padding-top:clamp(56px,10vh,110px);padding-bottom:clamp(48px,8vh,90px);">
      <div style="font-family:var(--mono);font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:var(--text-faint);margin-bottom:26px;">
        <a href={url('/')} style="color:var(--text-faint);">Home</a> &nbsp;/&nbsp; <span style="color:var(--accent);">Case Studies</span>
      </div>
      <div class="kicker-row" style="margin-bottom:24px;"><span class="eyebrow">Proof, not promises</span></div>
      <h1 class="display d-xl" data-reveal style="max-width:18ch;">The wells the industry said couldn't be done.</h1>
      <p class="lede" data-reveal style="max-width:64ch;margin-top:24px;">A 100% intercept success rate isn't a slogan — it's a record built on the hardest wells in the world, documented and regulator-witnessed. Selected projects, 2020 to present.</p>
    </div>
  </section>

  <!-- STAT STRIP -->
  <section style="background:var(--ground);border-bottom:1px solid var(--line);">
    <div class="wrap" style="display:grid;grid-template-columns:repeat(4,1fr);">
      {stats.map((s, i) => (
        <div style={`padding:26px 8px;${i ? 'border-left:1px solid var(--line);padding-left:28px;' : ''}`}>
          <div class="display" style="font-size:clamp(26px,3vw,40px);color:var(--accent);line-height:1;">{s.n}</div>
          <div class="faint" style="font-family:var(--mono);font-size:11px;letter-spacing:0.08em;text-transform:uppercase;margin-top:10px;">{s.l}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- FEATURED -->
  <section class="section">
    <div class="wrap">
      <div class="kicker-row" data-reveal style="margin-bottom:44px;"><span class="eyebrow">Featured projects</span></div>
      <div style="display:flex;flex-direction:column;gap:24px;">
        {featured.map((c) => (
          <a href={url('/case-studies/' + c.slug + '/')} class="tile tile--link" data-reveal style="display:grid;grid-template-columns:1fr 1.25fr;gap:0;background:var(--surface);">
            <div class="cine" style="min-height:280px;border-right:1px solid var(--line);display:flex;align-items:flex-end;padding:24px;">
              {c.img && <img src={url(c.img)} alt={c.name} />}
              <span class="eyebrow" style="position:relative;font-size:10px;">{c.scope.join(' · ')}</span>
            </div>
            <div style="padding:36px;display:flex;flex-direction:column;">
              <div class="faint" style="font-family:var(--mono);font-size:11px;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:12px;">{c.location} · {c.year}</div>
              <h2 class="h-card" style="font-size:26px;color:var(--text);margin-bottom:10px;">{c.name}</h2>
              <p style="font-size:15px;line-height:1.6;color:var(--text-dim);margin:0 0 22px;flex:1;">{c.title}</p>
              {c.result && (
                <div style="display:flex;align-items:baseline;gap:14px;border-top:1px solid var(--line);padding-top:18px;">
                  <span class="display" style="font-size:30px;color:var(--accent);">{c.result.metric}</span>
                  <span class="muted" style="font-size:13px;">{c.result.metricLabel}</span>
                </div>
              )}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FULL TRACK RECORD -->
  <section class="section" style="background:var(--ground-2);border-top:1px solid var(--line);">
    <div class="wrap">
      <div data-reveal style="margin-bottom:36px;">
        <div class="kicker-row" style="margin-bottom:22px;"><span class="eyebrow">Full project track record</span></div>
        <h2 class="display d-m">2020 to present.</h2>
      </div>
      <div class="hgrid" style="grid-template-columns:repeat(auto-fit,minmax(300px,1fr));" data-reveal>
        {all.map((c) => (
          <a href={url('/case-studies/' + c.slug + '/')} class="tile tile--link" style="padding:24px 22px;background:var(--ground);display:flex;flex-direction:column;gap:8px;">
            <div style="display:flex;justify-content:space-between;align-items:baseline;gap:12px;">
              <span class="h-card" style="font-size:17px;color:var(--text);">{c.name}</span>
              <span class="faint" style="font-family:var(--mono);font-size:11px;flex:none;">{c.year}</span>
            </div>
            <div class="faint" style="font-size:12.5px;">{c.location}</div>
            <div style="display:flex;flex-wrap:wrap;gap:6px;margin-top:4px;">
              {c.scope.slice(0, 3).map((s) => (
                <span style="font-family:var(--mono);font-size:10px;letter-spacing:0.04em;color:var(--text-dim);border:1px solid var(--line);padding:3px 8px;">{s}</span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <SiteFooter />
</Layout>

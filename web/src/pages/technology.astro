---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { url } from '../lib/links.js';
import { technology } from '../data/technology.js';

const methods = technology.filter((t) => t.kind === 'hardware');
// Software trio: the two pure-software tools plus EverReady's AI interpretation.
const software = [
  technology.find((t) => t.slug === 'topgun'),
  technology.find((t) => t.slug === 'clearcut'),
  { ...technology.find((t) => t.slug === 'everready'), softwareLabel: 'AI-Driven Passive Ranging', softwareDesc: 'Non-intrusive ranging interpretation from existing survey data — fully remote, AI-driven, with proprietary interference processing.' },
];

const compare = [
  { from: '~46 days', fromL: 'Wireline AMR', to: '~32 days', toL: 'AMR-while-drilling' },
  { from: '20+ runs', fromL: 'Wireline AMR', to: '4 runs', toL: 'AMR-while-drilling' },
  { from: 'baseline', fromL: 'injection power', to: '~10× stronger', toL: 'earlier, stronger locate' },
];
---
<Layout title="Technology — Magnetic Ranging Hardware & Software | Gunnar Energy Services" description="DeadAhead™, DeadSet™, CTRWD™, Torped™ and EverReady™ ranging methods, driven by TopGun™ — the only commercial end-to-end ranging software in the industry.">
  <SiteHeader />

  <!-- HERO -->
  <section class="dotgrid" style="background:var(--ground-2);border-bottom:1px solid var(--line);">
    <div class="wrap" style="padding-top:clamp(56px,10vh,110px);padding-bottom:clamp(56px,10vh,110px);">
      <div style="font-family:var(--mono);font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:var(--text-faint);margin-bottom:26px;">
        <a href={url('/')} style="color:var(--text-faint);">Home</a> &nbsp;/&nbsp; <span style="color:var(--accent);">Technology</span>
      </div>
      <div class="kicker-row" style="margin-bottom:24px;"><span class="eyebrow">Proprietary · Patented · In-house R&amp;D</span></div>
      <h1 class="display d-xl" data-reveal style="max-width:18ch;">A complete ranging arsenal. One software brain.</h1>
      <p class="lede" data-reveal style="max-width:64ch;margin-top:24px;">Gunnar builds, owns and operates its entire ranging toolset — hardware and software. Each method is matched to a well's specific geometry, access and risk profile, then driven by the only commercial end-to-end ranging software in the industry.</p>
    </div>
  </section>

  <!-- RANGING METHODS -->
  <section class="section">
    <div class="wrap">
      <div class="kicker-row" data-reveal style="margin-bottom:40px;"><span class="eyebrow">Ranging methods · Hardware</span></div>
      <div class="hgrid" style="grid-template-columns:repeat(auto-fit,minmax(260px,1fr));" data-reveal>
        {methods.map((m) => (
          <a href={url('/technology/' + m.slug + '/')} class="tile tile--link" style="padding:30px 26px;background:var(--ground);display:flex;flex-direction:column;">
            <div class="eyebrow eyebrow--dim" style="margin-bottom:14px;">{m.type}</div>
            <h3 class="h-card" style="font-size:24px;color:var(--accent);margin-bottom:12px;">{m.name}</h3>
            <p style="font-size:13.5px;line-height:1.6;color:var(--text-dim);margin:0 0 20px;flex:1;">{m.tagline}</p>
            <div style="border-top:1px solid var(--line);padding-top:14px;font-size:12px;">
              <div style="display:flex;justify-content:space-between;margin-bottom:7px;"><span class="faint" style="font-family:var(--mono);letter-spacing:0.06em;">RANGE</span><span style="color:var(--text);font-weight:600;">{m.range}</span></div>
              <div style="display:flex;justify-content:space-between;gap:10px;"><span class="faint" style="font-family:var(--mono);letter-spacing:0.06em;">BEST FOR</span><span style="color:var(--text-dim);text-align:right;">{m.best}</span></div>
            </div>
            <span style="margin-top:16px;font-family:var(--mono);font-size:11px;letter-spacing:0.1em;text-transform:uppercase;color:var(--accent);">View tool →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- SOFTWARE -->
  <section class="section" style="background:var(--ground-2);border-top:1px solid var(--line);">
    <div class="wrap">
      <div data-reveal style="max-width:62ch;margin-bottom:44px;">
        <div class="kicker-row" style="margin-bottom:24px;"><span class="eyebrow">Software &amp; AI</span></div>
        <h2 class="display d-l">The brain behind every intercept.</h2>
        <p class="lede" style="margin-top:20px;">TopGun™ turns raw magnetic data into real-time intercept decisions — the connective tissue that lets one team run engineering, ranging and steering as a single loop.</p>
      </div>
      <div class="hgrid" style="grid-template-columns:repeat(3,1fr);" data-reveal>
        {software.map((sw) => (
          <a href={url('/technology/' + sw.slug + '/')} class="tile tile--link" style="padding:30px 26px;background:var(--ground);">
            <div class="eyebrow" style="margin-bottom:12px;">{sw.softwareLabel || sw.type.replace('Software · ', '')}</div>
            <h3 class="h-card" style="font-size:22px;color:var(--text);margin-bottom:12px;">{sw.name}</h3>
            <p style="font-size:13.5px;line-height:1.6;color:var(--text-dim);margin:0 0 18px;">{sw.softwareDesc || sw.summary}</p>
            <span style="font-family:var(--mono);font-size:11px;letter-spacing:0.1em;text-transform:uppercase;color:var(--accent);">Learn more →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- DEADAHEAD FLAGSHIP -->
  <section class="section">
    <div class="wrap" style="display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center;">
      <div data-reveal>
        <div class="kicker-row" style="margin-bottom:22px;"><span class="eyebrow">Flagship innovation</span></div>
        <h2 class="display d-m" style="margin-bottom:22px;">DeadAhead™ — the world's first commercial wired-pipe ranging-while-drilling system.</h2>
        <p style="font-size:16px;line-height:1.7;color:var(--text-dim);margin:0 0 20px;">Continuous ranging from the bottom-hole assembly with no wireline trips, delivering ~10× the current injection of traditional wireline AMR — an earlier locate, stronger signal and zero re-entry runs.</p>
        <a href={url('/technology/deadahead/')} style="font-family:var(--mono);font-size:12px;letter-spacing:0.1em;text-transform:uppercase;color:var(--accent);">Explore DeadAhead™ →</a>
      </div>
      <div class="tile" data-reveal style="padding:36px;background:var(--surface);">
        <div class="eyebrow eyebrow--dim" style="margin-bottom:24px;">Wireline AMR vs. AMR-while-drilling</div>
        {compare.map((c) => (
          <div style="display:grid;grid-template-columns:1fr auto 1fr;gap:16px;align-items:center;padding:15px 0;border-top:1px solid var(--line);">
            <div><div class="display" style="font-size:21px;color:var(--text-faint);">{c.from}</div><div class="faint" style="font-size:11px;">{c.fromL}</div></div>
            <div style="font-family:var(--mono);color:var(--accent);font-size:16px;">→</div>
            <div><div class="display" style="font-size:21px;color:var(--text);">{c.to}</div><div style="font-size:11px;color:var(--text-dim);">{c.toL}</div></div>
          </div>
        ))}
        <p class="faint" style="font-size:11.5px;line-height:1.6;font-style:italic;margin:20px 0 0;">U.S. Patent 11,781,421 B2 — reaffirmed by USPTO PTAB (2025). Co-presented at SPE/ISCWSA #62, Alaska, Sept 2025.</p>
      </div>
    </div>
  </section>

  <SiteFooter />
</Layout>

---
import '../styles/global.css';
import { url } from '../lib/links.js';

interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Gunnar Energy Services',
  description = 'The independent specialist in active magnetic ranging and wellbore intercept — relief wells, blowout kills, plug & abandonment, CCUS and geothermal placement.',
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href={url('/assets/favicon.png')} />
    <link rel="apple-touch-icon" href={url('/assets/apple-touch-icon.png')} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#0A0C0F" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body>
    <slot />
    <script>
      // One quiet orchestrated moment: sections rise in as they enter view.
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const els = document.querySelectorAll('[data-reveal]');
      if (reduce || !('IntersectionObserver' in window)) {
        els.forEach((el) => el.classList.add('in'));
      } else {
        const io = new IntersectionObserver((entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
          });
        }, { threshold: 0.12, rootMargin: '0px 0px -8% 0px' });
        els.forEach((el) => io.observe(el));
      }
    </script>
  </body>
</html>

---
import { url } from '../lib/links.js';
const nav = [
  { t: 'Services', href: '/services/' },
  { t: 'Technology', href: '/technology/' },
  { t: 'Case Studies', href: '/case-studies/' },
  { t: 'Insights', href: '/insights/' },
  { t: 'Videos', href: '/videos/' },
  { t: 'About', href: '/about/' },
];
---
<div style="position:sticky;top:0;z-index:90;">
  <!-- emergency strip -->
  <div style="background:var(--ground-2);border-bottom:1px solid var(--line-2);">
    <div class="wrap" style="display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap;padding-top:9px;padding-bottom:9px;">
      <div style="display:flex;align-items:center;gap:10px;font-family:var(--mono);font-size:11px;letter-spacing:0.16em;text-transform:uppercase;color:var(--text-dim);">
        <span style="display:inline-block;width:6px;height:6px;border-radius:50%;background:var(--accent);box-shadow:0 0 0 3px rgba(254,238,0,0.18);"></span>
        24/7 Emergency Well Control &amp; Relief Well Response
      </div>
      <a href="tel:+18325550100" style="font-family:var(--mono);font-size:11.5px;letter-spacing:0.08em;color:var(--text);font-weight:600;">CALL +1 832 555 0100 →</a>
    </div>
  </div>
  <!-- main nav -->
  <header style="background:rgba(10,12,15,0.82);backdrop-filter:blur(10px);border-bottom:1px solid var(--line);">
    <div class="wrap" style="display:flex;align-items:center;justify-content:space-between;gap:24px;padding-top:18px;padding-bottom:18px;">
      <a href={url('/')} style="display:flex;align-items:center;gap:12px;">
        <span style="display:inline-flex;align-items:center;justify-content:center;width:28px;height:28px;border:1.5px solid var(--accent);border-radius:50%;"><span style="width:8px;height:8px;background:var(--accent);border-radius:50%;"></span></span>
        <span style="font-family:var(--display-n);font-weight:900;font-size:20px;letter-spacing:0.08em;color:var(--text);">GUNNAR</span>
      </a>
      <nav style="display:flex;align-items:center;gap:30px;font-family:var(--mono);font-size:12px;letter-spacing:0.1em;text-transform:uppercase;flex-wrap:wrap;">
        {nav.map((n) => (
          <a href={url(n.href)} style="color:var(--text-dim);transition:color .15s ease;" onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-dim)'">{n.t}</a>
        ))}
      </nav>
      <a href={url('/contact/')} class="btn btn-primary" style="padding:11px 18px;">Talk to an Engineer</a>
    </div>
  </header>
</div>

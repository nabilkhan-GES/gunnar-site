---
import { url } from '../lib/links.js';
const nav = [
  { t: 'Services', href: '/services/' },
  { t: 'Technology', href: '/technology/' },
  { t: 'Case Studies', href: '/case-studies/' },
  { t: 'Insights', href: '/insights/' },
  { t: 'Videos', href: '/videos/' },
  { t: 'About', href: '/about/' },
];
---
<div style="position:sticky;top:0;z-index:80;font-family:'Libre Franklin',-apple-system,sans-serif;">
  <div style="background:#0a1626;color:#eef1f6;border-bottom:1px solid rgba(254,238,0,0.45);">
    <div style="max-width:1240px;margin:0 auto;padding:8px 32px;display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap;">
      <div style="display:flex;align-items:center;gap:10px;font-family:'IBM Plex Mono',monospace;font-size:11.5px;letter-spacing:0.08em;color:#c3cee0;">
        <span style="display:inline-block;width:7px;height:7px;border-radius:50%;background:#feee00;box-shadow:0 0 0 3px rgba(254,238,0,0.25);"></span>
        24/7 EMERGENCY WELL CONTROL &amp; RELIEF WELL RESPONSE
      </div>
      <a href="tel:+18325550100" style="font-family:'IBM Plex Mono',monospace;font-size:12px;letter-spacing:0.06em;color:#eef1f6;font-weight:600;text-decoration:none;">CALL +1 832 555 0100 &nbsp;→</a>
    </div>
  </div>
  <header style="background:rgba(11,15,19,0.97);backdrop-filter:blur(8px);">
    <div style="max-width:1240px;margin:0 auto;padding:16px 32px;display:flex;align-items:center;justify-content:space-between;gap:24px;">
      <a href={url('/')} style="display:flex;align-items:center;gap:11px;text-decoration:none;">
        <span style="display:inline-flex;align-items:center;justify-content:center;width:30px;height:30px;border:2px solid #feee00;border-radius:50%;"><span style="width:9px;height:9px;background:#feee00;border-radius:50%;"></span></span>
        <span style="font-family:'Archivo',sans-serif;font-weight:900;font-size:21px;letter-spacing:0.04em;color:#eef1f6;">GUNNAR</span>
      </a>
      <nav style="display:flex;align-items:center;gap:26px;font-size:14px;color:#c3cee0;flex-wrap:wrap;">
        {nav.map((n) => (
          <a href={url(n.href)} class="navlink" style="color:#c3cee0;text-decoration:none;">{n.t}</a>
        ))}
      </nav>
      <a href={url('/contact/')} style="background:#feee00;color:#0a1626;font-weight:700;font-size:13.5px;padding:11px 18px;border-radius:3px;white-space:nowrap;text-decoration:none;">Talk to a Ranging Engineer</a>
    </div>
  </header>
</div>

---
import { url } from '../lib/links.js';
const columns = [
  {
    h: 'Services',
    links: [
      { t: 'Relief Well & Blowout Intercept', href: '/services/relief-wells/' },
      { t: 'Plug & Abandonment', href: '/services/plug-and-abandonment/' },
      { t: 'CCUS Well Integrity', href: '/services/ccus/' },
      { t: 'Geothermal Well Placement', href: '/services/geothermal/' },
      { t: 'Solution Mining', href: '/services/solution-mining/' },
      { t: 'Well Re-Entry & Milling', href: '/services/well-re-entry/' },
    ],
  },
  {
    h: 'Technology',
    links: [
      { t: 'DeadAhead™ AMR-WD', href: '/technology/deadahead/' },
      { t: 'DeadSet™ Wireline AMR', href: '/technology/deadset/' },
      { t: 'CTRWD™ Coiled Tubing', href: '/technology/ctrwd/' },
      { t: 'EverReady™ PMR', href: '/technology/everready/' },
      { t: 'TopGun™ Software', href: '/technology/topgun/' },
    ],
  },
  {
    h: 'Company',
    links: [
      { t: 'About Gunnar', href: '/about/' },
      { t: 'Case Studies', href: '/case-studies/' },
      { t: 'Insights & Blog', href: '/insights/' },
      { t: 'Video Library', href: '/videos/' },
      { t: 'YouTube Channel ↗', href: 'https://www.youtube.com/@GunnarEnergyServices', ext: true },
      { t: 'Contact', href: '/contact/' },
    ],
  },
];
---
<!-- CLOSING CTA -->
<section class="section dotgrid" style="background:var(--ground);border-top:1px solid var(--line);position:relative;overflow:hidden;">
  <div class="wrap" style="position:relative;">
    <div class="kicker-row" style="margin-bottom:26px;"><span class="eyebrow">Let's talk</span></div>
    <div style="display:flex;justify-content:space-between;align-items:flex-end;gap:40px;flex-wrap:wrap;">
      <h2 class="display d-l" style="max-width:16ch;">Have a well that has to be hit?</h2>
      <div style="display:flex;gap:14px;flex-wrap:wrap;">
        <a href="tel:+18325550100" class="btn btn-primary">24/7 Emergency: +1 832 555 0100</a>
        <a href={url('/contact/')} class="btn btn-ghost">Request a feasibility review →</a>
      </div>
    </div>
  </div>
</section>

<footer style="background:var(--ground-2);color:var(--text-dim);border-top:1px solid var(--line);">
  <div class="wrap" style="padding-top:60px;padding-bottom:40px;">
    <div style="display:grid;grid-template-columns:1.5fr 1fr 1fr 1fr;gap:40px;padding-bottom:44px;border-bottom:1px solid var(--line);">
      <div>
        <div style="margin-bottom:18px;">
          <img src={url('/assets/logo.png')} alt="Gunnar Energy Services" style="height:30px;width:auto;display:block;" />
        </div>
        <p style="font-size:14px;line-height:1.65;max-width:34ch;margin:0 0 16px;color:var(--text-dim);">The independent specialist in active magnetic ranging and wellbore intercept. Founded 2019 · California, Texas &amp; Australia.</p>
        <div style="font-family:var(--mono);font-size:12px;color:var(--text);">info@gunnarenergyservices.com</div>
      </div>
      {columns.map((col) => (
        <div>
          <div class="eyebrow eyebrow--dim" style="margin-bottom:16px;">{col.h}</div>
          {col.links.map((ln) => (
            <a
              href={ln.ext ? ln.href : url(ln.href)}
              target={ln.ext ? '_blank' : undefined}
              rel={ln.ext ? 'noopener' : undefined}
              style="display:block;font-size:14px;color:var(--text-dim);margin-bottom:10px;transition:color .15s ease;"
              onmouseover="this.style.color='var(--text)'" onmouseout="this.style.color='var(--text-dim)'"
            >{ln.t}</a>
          ))}
        </div>
      ))}
    </div>
    <div style="padding-top:24px;display:flex;justify-content:space-between;flex-wrap:wrap;gap:12px;font-family:var(--mono);font-size:11px;letter-spacing:0.08em;color:var(--text-faint);text-transform:uppercase;">
      <span>© 2026 Gunnar Energy Services — All rights reserved</span>
      <span>Relief Wells · Magnetic Ranging · P&amp;A · CCUS · Geothermal</span>
    </div>
  </div>
</footer>
